-- ============================================================================
-- test_continue_break.klc — KLC v1.0.5 continue/break 修复验证
-- ============================================================================

-- 测试1: 单层 while + break
fn test_while_break() {
    let mut i = 0
    while i < 10 {
        io.println(i)
        if i == 3 {
            break
        }
        i = i + 1
    }
    -- 预期输出: 0, 1, 2, 3 然后停止
}

-- 测试2: 单层 while + continue (跳过偶数)
fn test_while_continue() {
    let mut i = 0
    while i < 5 {
        i = i + 1
        if i == 2 or i == 4 {
            continue
        }
        io.println(i)
    }
    -- 预期输出: 1, 3, 5
}

-- 测试3: 嵌套循环 break (只跳出内层)
fn test_nested_break() {
    let mut i = 0
    while i < 3 {
        i = i + 1
        let mut j = 0
        while j < 5 {
            j = j + 1
            if j == 2 {
                break
            }
            io.println(i)
        }
    }
    -- 预期: 每轮内层循环只输出1次 i 值 (j==1时)，共3轮 → 3行输出
}

-- 测试4: 嵌套循环 continue (只影响内层)
fn test_nested_continue() {
    let mut a = 0
    while a < 2 {
        a = a + 1
        let mut b = 0
        while b < 3 {
            b = b + 1
            if b == 2 {
                continue
            }
            io.println(b)
        }
    }
    -- 预期: 每轮输出 1, 3 (跳过2)，共2轮外层 → 4行输出
}

-- 测试5: break 确保不提前退出函数 (外层代码仍执行)
fn test_break_does_not_return() {
    let mut x = 0
    while x < 5 {
        x = x + 1
        if x == 2 {
            break
        }
    }
    -- break 后应该继续执行到这里
    io.println(x)  -- 预期输出: 2
}

fn main() {
    io.println("=== 测试1: while + break ===")
    test_while_break()

    io.println("=== 测试2: while + continue ===")
    test_while_continue()

    io.println("=== 测试3: 嵌套 break ===")
    test_nested_break()

    io.println("=== 测试4: 嵌套 continue ===")
    test_nested_continue()

    io.println("=== 测试5: break 不 return ===")
    test_break_does_not_return()

    io.println("=== 全部测试完成 ===")
}
