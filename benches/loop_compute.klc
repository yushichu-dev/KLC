-- loop_compute.klc — 常量折叠 + 常量传播基准测试
-- 循环内包含多层常量表达式链
-- 优化版: 常量全部折叠为立即数，中间变量消除，sum += -30
-- 未优化版: 每次迭代计算 3 个中间变量，4 次内存读写

let mut sum = 0
for i in 0..5000000 {
    let c1 = 100 * 50
    let c2 = c1 + 250
    let c3 = c2 / 75
    let c = c3 - 100
    sum = sum + c
}
-- c1=5000, c2=5250, c3=70, c=-30
-- sum = 5000000 * (-30) = -150000000
if sum != -150000000 {
    exit(1)
}
println("PASS")
