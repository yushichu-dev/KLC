type A {
    x: i64
}

type B {
    y: i64
}

impl A {
    fn create(x: i64) -> A {
        return A { x: x }
    }
    fn show(self) -> str {
        return self.x.to_str()
    }
}

impl B {
    fn create(y: i64) -> B {
        return B { y: y }
    }
    fn show(self) -> str {
        return self.y.to_str()
    }
}

fn main() {
    let a = A::create(42)
    let b = B::create(99)
    io.println(a.show())
    io.println(b.show())
}
