--- 完整演示：端到端推理流程
fn demo_inference_engine() {
    io.println("╔══════════════════════════════════════════════╗")
    io.println("║     KLC:3B 推理引擎 — 完整演示                ║")
    io.println("╚══════════════════════════════════════════════╝")
    io.println()

    -- 步骤 1: 创建引擎（不加载真实权重，使用演示模式）
    io.println("步骤 1: 创建推理引擎")

    -- 注：实际使用时传入真实的权重文件路径
    -- let engine = KLC3BInferenceEngine::new("models/klc_3b.klcw", "tokenizer.json")

    -- 演示：创建轻量级引擎用于展示流程
    let engine = KLC3BInferenceEngine::new("", "")
    -- 手动标记为已加载（演示用）
    engine.is_model_loaded = true
    engine.token_embedding_weight = Tensor::zeros(
        Shape { dims: [DEFAULT_VOCAB_SIZE, DEFAULT_HIDDEN_SIZE] }
    )
    engine.final_norm_weight = Tensor::zeros(Shape { dims: [DEFAULT_HIDDEN_SIZE] })
    engine.lm_head_weight = Tensor::zeros(
        Shape { dims: [DEFAULT_HIDDEN_SIZE, DEFAULT_VOCAB_SIZE] }
    )
    engine.kv_cache = KVCacheManager::new(
        DEFAULT_NUM_LAYERS, DEFAULT_NUM_KV_HEADS, DEFAULT_HEAD_DIM,
        DEFAULT_MAX_POSITION, 1, engine.pool
    )

    io.println("  ✓ 引擎创建成功（演示模式）")
    io.println()

    -- 步骤 2: 配置生成参数
    io.println("步骤 2: 配置生成参数")

    let gen_config = GenerationConfig {
        max_new_tokens: 128,
        min_new_tokens: 10,
        sampling: SamplingConfig::default(),
        stop_token_ids: [EOS_TOKEN_ID],
        skip_special_tokens: true,
        echo_prompt: false,
        stream: false,
        return_full_text: false,
        batch_size: 1
    }

    io.println("  最大长度: " ++ gen_config.max_new_tokens.to_str())
    io.println("  温度: " ++ ("%.2f" % gen_config.sampling.temperature))
    io.println("  Top-K: " ++ gen_config.sampling.top_k.to_str())
    io.println("  Top-P: " ++ ("%.2f" % gen_config.sampling.top_p))
    io.println()

    -- 步骤 3: 执行推理
    io.println("步骤 3: 执行推理")

    let test_prompts = [
        "Hello, my name is",
        "What is artificial intelligence?",
        "请介绍KLC编程语言的特点。",
        "Write a Python function to calculate fibonacci."
    ]

    for prompt in test_prompts {
        io.println("-" .repeat(50))
        io.println("Prompt: " ++ prompt)

        -- 实际推理（演示模式下会使用模拟权重）
        let result = engine.generate(prompt, gen_config)

        io.println()
        io.println("-" .repeat(50))
        io.println()
    }

    -- 步骤 4: 展示对话模式
    io.println("步骤 4: 多轮对话演示")
    io.println("-" .repeat(50))

    let history = ConversationHistory::new(max_rounds=5)
    history.add_message("system", "你是KLC编程语言的AI助手，请用中文回答问题。")

    let questions = [
        "KLC是什么？",
        "它有哪些特点？",
        "如何安装KLC？",
        "能给我写个Hello World吗？"
    ]

    for q in questions {
        io.print("[User]: " ++ q ++ "\n")

        let answer = chat(engine, history, q, gen_config)
        io.println("[Assistant]: " ++ answer)
        io.println()
    }

    -- 步骤 5: 统计信息
    io.println("步骤 5: 引擎统计")
    io.println("-" .repeat(50))
    engine.print_stats()

    -- 步骤 6: 不同采样策略对比
    io.println()
    io.println("步骤 6: 采样策略对比")
    io.println("-" .repeat(50))

    let strategies = [
        ("贪心 (Greedy)", SamplingConfig::greedy()),
        ("默认 (Default)", SamplingConfig::default()),
        ("精确 (Precise)", SamplingConfig::precise()),
        ("创意 (Creative)", SamplingConfig::creative())
    ]

    let demo_prompt = "The future of AI is"

    for (name, strategy) in strategies {
        let custom_config = GenerationConfig {
            max_new_tokens: 64,
            min_new_tokens: 10,
            sampling: strategy,
            stop_token_ids: [EOS_TOKEN_ID],
            skip_special_tokens: true,
            echo_prompt: false,
            stream: false,
            return_full_text: false,
            batch_size: 1
        }

        io.println(name ++ ":")
        let result = engine.generate(demo_prompt, custom_config)
        io.println("  " ++ result.text)
        io.println("  (TPS: " ++ ("%.2f" % result.tokens_per_second) ++ ")")
        io.println()
    }

    io.println()
    io.println("═══════════════════════════════════════════")
    io.println("  ✓ 推理引擎演示完成")
    io.println("  提示: 使用真实权重文件可获得完整AI能力")
    io.println("═══════════════════════════════════════════")
}

fn main() {
    demo_inference_engine()
}
