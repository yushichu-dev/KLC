--- 一行代码加载模型（便捷 API）
---
--- 示例：
---   let engine = quick_load("models/klc_3b.klcw", "tokenizer.json")
pub fn quick_load(weight_path: str, tokenizer_path: str = "") -> KLC3BInferenceEngine {
    let engine = KLC3BInferenceEngine::new(weight_path, tokenizer_path)
    engine.load_model()
    return engine
}

--- 一行代码生成文本（便捷 API）
---
--- 示例：
---   let answer = ask_ai(engine, "什么是人工智能？")
pub fn ask_ai(engine: KLC3BInferenceEngine mut, question: str) -> str {
    let result = engine.generate(question)
    return result.text
}

--- 对话模式（多轮对话）
---
--- 维护对话历史，支持上下文理解
type ConversationHistory {
    messages: [(str, str)]  -- [(role, content)]
    max_history: i64        -- 保留的最大轮次
}

impl ConversationHistory {
    pub fn new(max_rounds: i64 = 10) -> ConversationHistory {
        return ConversationHistory {
            messages: [],
            max_history: max_rounds
        }
    }

    pub fn add_message(self mut, role: str, content: str) {
        self.messages.push((role, content))

        -- 裁剪历史
        while self.messages.len() > self.max_history * 2 {
            remove(self.messages, 0)
        }
    }

    pub fn format_prompt(self) -> str {
        let mut prompt = ""

        for (role, content) in self.messages {
            match role {
                "system" => {
                    prompt = prompt ++ "[System]\n" ++ content ++ "\n\n"
                },
                "user" => {
                    prompt = prompt ++ "[User]\n" ++ content ++ "\n\n"
                },
                "assistant" => {
                    prompt = prompt ++ "[Assistant]\n" ++ content ++ "\n\n"
                },
                _ => {}
            }
        }

        prompt = prompt ++ "[Assistant]\n"
        return prompt
    }
}

--- 执行多轮对话
pub fn chat(
    engine: KLC3BInferenceEngine mut,
    history: ConversationHistory mut,
    user_input: str,
    config: GenerationConfig? = null
) -> str {
    -- 添加用户消息
    history.add_message("user", user_input)

    -- 格式化 prompt
    let prompt = history.format_prompt()

    -- 生成回复
    let result = engine.generate(prompt, config)

    -- 添加助手回复到历史
    history.add_message("assistant", result.text)

    return result.text
}

