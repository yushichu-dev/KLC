mod test_v084_features

-- Test 1: math library
pub fn test_math() {
    let e = math.exp(0.0)
    let s = math.sqrt(4.0)
    io.println("math.exp(0)=" ++ e.to_str())
    io.println("math.sqrt(4)=" ++ s.to_str())
    io.println("Test math: PASSED")
}

-- Test 2: for loop
pub fn test_for() {
    let mut sum = 0
    for i in 0..5 {
        sum = sum + i
    }
    io.println("sum 0..5 = " ++ sum.to_str())
    io.println("Test for: PASSED")
}

-- Test 3: match
pub fn test_match() {
    let result = match "hello" {
        "hello" => "greeting"
        "world" => "planet"
        _ => "unknown"
    }
    io.println("match result: " ++ result)
    io.println("Test match: PASSED")
}

-- Test 4: Option<T>
pub fn test_option() {
    let x: Option<i64> = Some(42)
    let val = if let Some(v) = x { v } else { 0 }
    let y: Option<i64> = None
    let none_val = match y {
        Some(v) => v
        None => -1
    }
    io.println("Some: " ++ val.to_str() ++ " None: " ++ none_val.to_str())
    io.println("Test option: PASSED")
}

-- Test 5: Map
pub fn test_map() {
    let m = {"hello": 1, "world": 2}
    let v1 = m["hello"]
    let v2 = m["world"]
    io.println("map[hello]=" ++ v1.to_str() ++ " map[world]=" ++ v2.to_str())
    io.println("Test map: PASSED")
}

-- Test 6: type + impl (no pub in impl)
type Vec4 {
    d0: f64
    d1: f64
}

impl Vec4 {
    fn new(a: f64, b: f64) -> Vec4 = Vec4 { d0: a, d1: b }
    fn scale(self, s: f64) -> Vec4 = Vec4 { d0: self.d0 * s, d1: self.d1 * s }
}

pub fn test_impl() {
    let v = Vec4::new(3.0, 4.0)
    let vs = v.scale(2.0)
    io.println("Vec4 scaled: " ++ vs.d0.to_str() ++ ", " ++ vs.d1.to_str())
    io.println("Test impl: PASSED")
}

-- Test 7: pub fn at module level
pub fn my_helper(x: i64) -> i64 = x + 1

pub fn test_pub_fn() {
    let r = my_helper(10)
    io.println("pub fn result: " ++ r.to_str())
    io.println("Test pub fn: PASSED")
}

fn main() {
    test_math()
    test_for()
    test_match()
    test_option()
    test_map()
    test_impl()
    test_pub_fn()
    io.println("")
    io.println("All 7 v0.8.4 feature tests PASSED!")
}
