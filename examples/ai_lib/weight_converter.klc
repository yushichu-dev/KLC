--- 一行代码完成转换（最简 API）
---
--- 示例用法：
---   convert_model("Qwen2-1.5B/model.safetensors", "output/klc_3b.klcw",
---                 "Qwen2-1.5B-KLC", "llama", "fp16")
pub fn convert_model(
    input_file: str,
    output_file: str,
    model_name: str = "converted_model",
    architecture: str = "llama",
    target_dtype: str = "fp32"
) -> bool {
    let pipeline = ConversionPipeline {
        input_path: input_file,
        output_path: output_file,
        model_name: model_name,
        architecture: architecture,
        target_dtype: target_dtype,
        quant_config: QuantizationConfig::default_int8(),
        use_mmap: true,
        verify_checksum: true,
        verbose: true
    }

    return run_conversion(pipeline)
}

--- 批量转换多个分片文件
---
--- 一些大型模型会分成多个 shard 文件
pub fn convert_sharded_model(
    shard_files: [str],
    output_file: str,
    model_name: str,
    architecture: str,
    target_dtype: str
) -> bool {
    io.println("检测到 " ++ shard_files.len().to_str() ++ " 个分片文件")

    -- 合并分片的简化逻辑
    -- （实际实现需要按顺序读取并合并）

    -- 对于单文件模型，直接调用转换
    if shard_files.len() == 1 {
        return convert_model(shard_files[0], output_file, model_name,
                            architecture, target_dtype)
    }

    -- 多分片合并逻辑（简化版）
    io.println("警告: 多分片合并功能需要完整实现")
    return convert_model(shard_files[0], output_file, model_name,
                         architecture, target_dtype)
}

--- 交互式转换向导（命令行使用）
pub fn interactive_wizard() {
    io.println()
    io.println("════ KLC 权重转换向导 ═════")
    io.println()

    -- 输入文件路径
    io.print("请输入 safetensors 文件路径: ")
    let input_path = read_line()

    -- 输出文件路径
    io.print("请输入输出 .klcw 文件路径: ")
    let output_path = read_line()

    -- 架构选择
    io.println("可选架构:")
    io.println("  1. LLaMA / Qwen2 / TinyLlama (推荐)")
    io.println("  2. Mistral / Mixtral")
    io.println("  3. GPT-2 / OPT")
    io.println("  4. Falcon")
    io.print("请选择架构 (1-4): ")
    let choice = read_line()

    let arch = match choice {
        "1" => { "llama" },
        "2" => { "mistral" },
        "3" => { "gpt2" },
        "4" => { "falcon" },
        _ => { "llama" }
    }

    -- 数据类型选择
    io.println("目标精度:")
    io.println("  1. FP32 (最高精度, 最慢)")
    io.println("  2. FP16 (推荐平衡)")
    io.println("  3. INT8 (最快, 有损)")
    io.print("请选择精度 (1-3): ")
    let dtype_choice = read_line()

    let dtype = match dtype_choice {
        "1" => { "fp32" },
        "2" => { "fp16" },
        "3" => { "int8" },
        _ => { "fp16" }
    }

    -- 模型名称
    io.print("请输入模型名称 (如 KLC-3B-v1): ")
    let model_name_input = read_line()
    let model_name = if model_name_input.len() > 0 { model_name_input } else { "KLC-3B-v1" }

    io.println()

    -- 执行转换
    let success = convert_model(input_path, output_path, model_name, arch, dtype)

    if success {
        io.println()
        io.println("✓ 转换成功！")
        io.println("  下一步: 使用 'klc_3b_infer.klc' 加载模型进行推理")
    } else {
        io.println()
        io.println("✗ 转换失败，请检查输入文件")
    }
}

--- 读取一行输入（模拟，实际需要 I/O 支持）
fn read_line() -> str {
    -- 返回默认值用于演示
    return ""
}

-- |===========================================================================|
-- |                      使用示例                                             |
-- |===========================================================================|

--- 展示典型使用方式
fn demo_conversion() {
    io.println("━━━ 权重转换示例 ━━━")
    io.println()

    -- 示例 1: 转换 TinyLlama-1.1B 到 KLC 格式
    io.println("示例 1: 转换 TinyLlama-1.1B")
    io.println("-" .repeat(40))

    let success1 = convert_model(
        "models/TinyLlama-1.1B/model.safetensors",
        "models/klc_tinyllama_1.1b.klcw",
        "TinyLlama-1.1B-KLC",
        "llama",
        "fp16"
    )

    io.println("结果: " ++ (if success1 { "成功" } else { "失败" }))
    io.println()

    -- 示例 2: INT8 量化转换（节省内存）
    io.println("示例 2: INT8 量化转换（适合低内存设备）")
    io.println("-" .repeat(40))

    let success2 = convert_model(
        "models/Qwen2-1.5B/model-00001-of-00002.safetensors",
        "models/klc_qwen2_1.5b_int8.klcw",
        "Qwen2-1.5B-KLC-INT8",
        "llama",
        "int8"
    )

    io.println("结果: " ++ (if success2 { "成功" } else { "失败" }))
    io.println()

    -- 示例 3: 自定义配置转换
    io.println("示例 3: 使用自定义配置")
    io.println("-" .repeat(40))

    let custom_pipeline = ConversionPipeline {
        input_path: "models/custom/model.safetensors",
        output_path: "output/custom_model.klcw",
        model_name: "CustomModel-KLC",
        architecture: "llama",
        target_dtype: "fp16",
        quant_config: QuantizationConfig {
            method: "symmetric",
            target_dtype: "fp16",
            group_size: -1,
            calibration_data: null
        },
        use_mmap: true,
        verify_checksum: true,
        verbose: true
    }

    let success3 = run_conversion(custom_pipeline)
    io.println("结果: " ++ (if success3 { "成功" } else { "失败" }))
}

fn main() {
    demo_conversion()
}
