-- 第六部分：分词器接口
-- ══════════════════════════════════════════════════════════════════

type VocabEntry {
    token: str
    id: i64
}

type MiniTokenizer {
    vocab: [VocabEntry]
    bos_id: i64
    eos_id: i64
    pad_id: i64
    unk_id: i64
}

impl MiniTokenizer {
    fn create() -> MiniTokenizer {
        let vocab = init_vocab()
        return MiniTokenizer {
            vocab: vocab,
            bos_id: 2, eos_id: 3, pad_id: 0, unk_id: 1
        }
    }

    fn encode(self, text: str, add_special: bool) -> [i64] {
        if text.len() == 0 {
            if add_special { return [self.bos_id, self.eos_id] }
            return []
        }
        let mut ids = []
        if add_special { ids.push(self.bos_id) }
        let chars_arr = str_to_chars(text)
        let mut i = 0
        while i < chars_arr.len() {
            let ch = chars_arr[i]
            let cid = lookup_id(ch, self.vocab)
            ids.push(cid)
            i = i + 1
        }
        if add_special { ids.push(self.eos_id) }
        return ids
    }

    fn decode(self, ids: [i64], skip_special: bool) -> str {
        let mut parts = []
        let mut i = 0
        while i < ids.len() {
            let id = ids[i]
            if not skip_special or (id != self.bos_id and id != self.eos_id
                                    and id != self.pad_id) {
                let tok = lookup_token(id, self.vocab)
                if tok != "<UNK>" and tok != "<PAD>" {
                    parts.push(tok)
                }
            }
            i = i + 1
        }
        return join_str(parts, "")
    }
}

