-- ============================================================================
-- KLC:AI Inference Engine v2.0 - AI底座第三阶段（端到端推理）
-- 升级至 KLC v1.0.3-正式版 语法（原生 math 库 / while 循环 / pub / match）
--
-- 核心模块：
--   1. KV 缓存（加速自回归生成）
--   2. LM Head（词表概率输出 + 数值稳定 Softmax）
--   3. 采样算法（Temperature / Top-K / Top-P / Repetition Penalty）
--   4. 多层 Transformer 推理内核
--   5. 自回归生成循环（逐 Token 生成 + EOS 终止）
--   6. 端到端管道（文本输入 → BPE 编码 → 推理 → 采样 → 解码 → 输出）
--
-- 适配模型：KLC:3B / KLC-POR:9B / KLC-UIT-POR:18B / KLC-MAX:27B
-- KLC VM 限制：for 循环不能修改外部 mut 变量，所有循环使用 while
-- ============================================================================

mod inference_engine

-- ══════════════════════════════════════════════════════════════════
-- 第一部分：域特定激活函数（基于原生 math 标准库）
-- ══════════════════════════════════════════════════════════════════

pub fn abs1(x: f64) -> f64 = if x >= 0.0 { x } else { -x }

pub fn sign(x: f64) -> f64 {
    if x > 0.0 { return 1.0 }
    if x < 0.0 { return -1.0 }
    return 0.0
}

pub fn relu(x: f64) -> f64 = if x > 0.0 { x } else { 0.0 }

pub fn sigmoid(x: f64) -> f64 {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + math::exp(-x))
}

pub fn silu(x: f64) -> f64 = x * sigmoid(x)

pub fn gelu(x: f64) -> f64 {
    let k = 0.7978845608
    let inner = k * (x + 0.044715 * x * x * x)
    return 0.5 * x * (1.0 + math::tanh(inner))
}

fn apply_silu_to_vec(v: Vec4) -> Vec4 = Vec4 {
    d0: silu(v.d0), d1: silu(v.d1),
    d2: silu(v.d2), d3: silu(v.d3)
}

-- ══════════════════════════════════════════════════════════════════
-- 第二部分：向量工具 Vec4
-- ══════════════════════════════════════════════════════════════════

type Vec4 {
    d0: f64
    d1: f64
    d2: f64
    d3: f64
}

impl Vec4 {
    fn new(v0: f64, v1: f64, v2: f64, v3: f64) -> Vec4 =
        Vec4 { d0: v0, d1: v1, d2: v2, d3: v3 }

    fn zeros() -> Vec4 = Vec4 { d0: 0.0, d1: 0.0, d2: 0.0, d3: 0.0 }

    fn ones() -> Vec4 = Vec4 { d0: 1.0, d1: 1.0, d2: 1.0, d3: 1.0 }

    fn add(self, o: Vec4) -> Vec4 = Vec4 {
        d0: self.d0 + o.d0, d1: self.d1 + o.d1,
        d2: self.d2 + o.d2, d3: self.d3 + o.d3
    }

    fn sub(self, o: Vec4) -> Vec4 = Vec4 {
        d0: self.d0 - o.d0, d1: self.d1 - o.d1,
        d2: self.d2 - o.d2, d3: self.d3 - o.d3
    }

    fn mul(self, o: Vec4) -> Vec4 = Vec4 {
        d0: self.d0 * o.d0, d1: self.d1 * o.d1,
        d2: self.d2 * o.d2, d3: self.d3 * o.d3
    }

    fn scale(self, s: f64) -> Vec4 = Vec4 {
        d0: self.d0 * s, d1: self.d1 * s,
        d2: self.d2 * s, d3: self.d3 * s
    }

    fn dot(self, o: Vec4) -> f64 =
        self.d0 * o.d0 + self.d1 * o.d1 + self.d2 * o.d2 + self.d3 * o.d3

    fn sum_sq(self) -> f64 =
        self.d0 * self.d0 + self.d1 * self.d1 + self.d2 * self.d2 + self.d3 * self.d3

    fn norm(self) -> f64 = math::sqrt(self.sum_sq())

    fn abs_vec(self) -> Vec4 = Vec4 {
        d0: abs1(self.d0), d1: abs1(self.d1),
        d2: abs1(self.d2), d3: abs1(self.d3)
    }

    fn show(self) -> str =
        "[" ++ self.d0.to_str() ++ ", " ++ self.d1.to_str() ++ ", " ++
        self.d2.to_str() ++ ", " ++ self.d3.to_str() ++ "]"
}

-- ══════════════════════════════════════════════════════════════════
-- 第三部分：模型配置（全系列 4 规格）
-- ══════════════════════════════════════════════════════════════════

type ModelConfig {
    name: str
    hidden_size: i64
    num_layers: i64
    num_heads: i64
    head_dim: i64
    intermediate_size: i64
    vocab_size: i64
    rms_eps: f64
    max_seq_len: i64
    rope_theta: f64
}

impl ModelConfig {
    fn params_count(self) -> i64 {
        let h = self.hidden_size
        let n = self.num_layers
        let ff = self.intermediate_size
        let v = self.vocab_size
        let attn = 4 * h * h
        let ffn = 5 * h * ff
        let layer = attn + ffn
        return n * layer + v * h
    }

    fn klc_3b_config() -> ModelConfig = ModelConfig {
        name: "KLC:3B", hidden_size: 2560, num_layers: 28,
        num_heads: 32, head_dim: 80,
        intermediate_size: 6912, vocab_size: 64000,
        rms_eps: 0.000001, max_seq_len: 4096, rope_theta: 10000.0
    }

    fn klc_9b_config() -> ModelConfig = ModelConfig {
        name: "KLC-POR:9B", hidden_size: 3584, num_layers: 36,
        num_heads: 56, head_dim: 64,
        intermediate_size: 18944, vocab_size: 128000,
        rms_eps: 0.00001, max_seq_len: 8192, rope_theta: 1000000.0
    }

    fn klc_18b_config() -> ModelConfig = ModelConfig {
        name: "KLC-UIT-POR:18B", hidden_size: 4608, num_layers: 40,
        num_heads: 72, head_dim: 64,
        intermediate_size: 21504, vocab_size: 128000,
        rms_eps: 0.00001, max_seq_len: 16384, rope_theta: 1000000.0
    }

    fn klc_27b_config() -> ModelConfig = ModelConfig {
        name: "KLC-MAX:27B", hidden_size: 5120, num_layers: 48,
        num_heads: 80, head_dim: 64,
        intermediate_size: 27648, vocab_size: 128000,
        rms_eps: 0.00001, max_seq_len: 16384, rope_theta: 1000000.0
    }

    fn mini_test_config() -> ModelConfig = ModelConfig {
        name: "TestMini", hidden_size: 32, num_layers: 2,
        num_heads: 4, head_dim: 8,
        intermediate_size: 86, vocab_size: 256,
        rms_eps: 0.000001, max_seq_len: 128, rope_theta: 10000.0
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第四部分：RMSNorm / RoPE / MHA / SwiGLU FFN / TransformerBlock
-- ══════════════════════════════════════════════════════════════════

type RMSNormLayer {
    dim: i64
    eps: f64
    weight: Vec4
}

impl RMSNormLayer {
    fn create(size: i64, epsilon: f64) -> RMSNormLayer {
        return RMSNormLayer { dim: size, eps: epsilon, weight: Vec4::ones() }
    }

    fn create_w(size: i64, epsilon: f64, w: Vec4) -> RMSNormLayer {
        return RMSNormLayer { dim: size, eps: epsilon, weight: w }
    }

    fn norm_apply(self, x: Vec4) -> Vec4 {
        let ss = x.sum_sq()
        let mean_ss = ss / self.dim as f64
        let rms = math::sqrt(mean_ss + self.eps)
        let sc = 1.0 / rms
        return Vec4 {
            d0: x.d0 * sc * self.weight.d0,
            d1: x.d1 * sc * self.weight.d1,
            d2: x.d2 * sc * self.weight.d2,
            d3: x.d3 * sc * self.weight.d3
        }
    }
}

-- ── RoPE 旋转位置编码 ──

type RopeEncoder {
    head_dim: i64
    max_pos: i64
    base: f64
    freqs: [f64]
    cos_cache: [f64]
    sin_cache: [f64]
}

impl RopeEncoder {
    fn create(dim: i64, max_seq: i64, theta_base: f64) -> RopeEncoder {
        let mut encoder = RopeEncoder {
            head_dim: dim, max_pos: max_seq, base: theta_base,
            freqs: [], cos_cache: [], sin_cache: []
        }
        let half_dim = dim / 2
        let mut i = 0
        while i < half_dim {
            let exponent = -2.0 * i as f64 / dim as f64
            let theta = math::pow(theta_base, exponent)
            encoder.freqs.push(theta)
            i = i + 1
        }
        let mut pos = 0
        while pos < max_seq {
            let mut di = 0
            while di < half_dim {
                let angle = pos as f64 * encoder.freqs[di]
                encoder.cos_cache.push(math::cos(angle))
                encoder.sin_cache.push(math::sin(angle))
                di = di + 1
            }
            pos = pos + 1
        }
        return encoder
    }

    fn apply(self, x: Vec4, position: i64) -> Vec4 {
        if position < 0 or position >= self.max_pos {
            return x
        }
        let half_dim = self.head_dim / 2
        let offset = position * half_dim
        let c0 = self.cos_cache[offset + 0]
        let s0 = self.sin_cache[offset + 0]
        let c1 = self.cos_cache[offset + 1]
        let s1 = self.sin_cache[offset + 1]
        return Vec4 {
            d0: x.d0 * c0 - x.d1 * s0,
            d1: x.d0 * s0 + x.d1 * c0,
            d2: x.d2 * c1 - x.d3 * s1,
            d3: x.d2 * s1 + x.d3 * c1
        }
    }
}

-- ── 多头注意力机制 ──

type MHAttention {
    config: ModelConfig
    wq_scale: f64
    wk_scale: f64
    wv_scale: f64
    wo_scale: f64
    rope: RopeEncoder
}

impl MHAttention {
    fn create(cfg: ModelConfig) -> MHAttention {
        return MHAttention {
            config: cfg,
            wq_scale: 0.1, wk_scale: 0.1, wv_scale: 0.1, wo_scale: 1.0,
            rope: RopeEncoder::create(cfg.head_dim, cfg.max_seq_len, cfg.rope_theta)
        }
    }

    fn create_scales(cfg: ModelConfig, wq: f64, wk: f64, wv: f64, wo: f64) -> MHAttention {
        return MHAttention {
            config: cfg, wq_scale: wq, wk_scale: wk, wv_scale: wv, wo_scale: wo,
            rope: RopeEncoder::create(cfg.head_dim, cfg.max_seq_len, cfg.rope_theta)
        }
    }

    fn attn_apply(self, x: Vec4, position: i64) -> Vec4 {
        let d_k = self.config.head_dim as f64
        let q = x.scale(self.wq_scale)
        let k = x.scale(self.wk_scale)
        let v = x.scale(self.wv_scale)
        let q_rope = self.rope.apply(q, position)
        let k_rope = self.rope.apply(k, position)
        let raw_score = q_rope.dot(k_rope) / math::sqrt(d_k)
        let e = math::exp(raw_score)
        let output = v.scale(e)
        return output.scale(self.wo_scale)
    }
}

-- ── SwiGLU 前馈网络 ──

type SwigluFFN {
    config: ModelConfig
    gate_scale: f64
    up_scale: f64
    down_scale: f64
}

impl SwigluFFN {
    fn create(cfg: ModelConfig) -> SwigluFFN {
        return SwigluFFN {
            config: cfg,
            gate_scale: 1.0, up_scale: 1.0,
            down_scale: 1.0 / cfg.intermediate_size as f64
        }
    }

    fn create_scales(cfg: ModelConfig, gate: f64, up: f64, down: f64) -> SwigluFFN {
        return SwigluFFN { config: cfg, gate_scale: gate, up_scale: up, down_scale: down }
    }

    fn ffn_apply(self, x: Vec4) -> Vec4 {
        let gated = x.scale(self.gate_scale)
        let activated_gated = apply_silu_to_vec(gated)
        let upped = x.scale(self.up_scale)
        let gated_mul = activated_gated.mul(upped)
        return gated_mul.scale(self.down_scale)
    }
}

-- ── Transformer Block（Pre-Norm + 残差） ──

type TransformerBlock {
    config: ModelConfig
    attn_norm: RMSNormLayer
    attention: MHAttention
    ffn_norm: RMSNormLayer
    feed_forward: SwigluFFN
}

impl TransformerBlock {
    fn create(cfg: ModelConfig) -> TransformerBlock {
        return TransformerBlock {
            config: cfg,
            attn_norm: RMSNormLayer::create(cfg.hidden_size, cfg.rms_eps),
            attention: MHAttention::create(cfg),
            ffn_norm: RMSNormLayer::create(cfg.hidden_size, cfg.rms_eps),
            feed_forward: SwigluFFN::create(cfg)
        }
    }

    fn create_w(
        cfg: ModelConfig,
        attn_w: Vec4, ffn_w: Vec4,
        wq: f64, wk: f64, wv: f64, wo: f64,
        gate: f64, up: f64, down: f64
    ) -> TransformerBlock {
        return TransformerBlock {
            config: cfg,
            attn_norm: RMSNormLayer::create_w(cfg.hidden_size, cfg.rms_eps, attn_w),
            attention: MHAttention::create_scales(cfg, wq, wk, wv, wo),
            ffn_norm: RMSNormLayer::create_w(cfg.hidden_size, cfg.rms_eps, ffn_w),
            feed_forward: SwigluFFN::create_scales(cfg, gate, up, down)
        }
    }

    fn block_apply(self, x: Vec4, position: i64) -> Vec4 {
        let normed_x = self.attn_norm.norm_apply(x)
        let attn_out = self.attention.attn_apply(normed_x, position)
        let h = x.add(attn_out)
        let normed_h = self.ffn_norm.norm_apply(h)
        let ffn_out = self.feed_forward.ffn_apply(normed_h)
        return h.add(ffn_out)
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第五部分(1): KV 缓存 — 不可变追加模式
-- ══════════════════════════════════════════════════════════════════

type KVPair {
    key: Vec4
    value: Vec4
}

type KVCache {
    keys: [Vec4]
    values: [Vec4]
    count: i64
    max_size: i64
}

impl KVCache {
    fn create(max_seq: i64) -> KVCache {
        return KVCache { keys: [], values: [], count: 0, max_size: max_seq }
    }

    fn push(self, k: Vec4, v: Vec4) -> KVCache {
        if self.count < self.max_size {
            let mut new_keys = []
            let mut ki = 0
            while ki < self.count {
                new_keys.push(self.keys[ki])
                ki = ki + 1
            }
            new_keys.push(k)
            let mut new_values = []
            let mut vi = 0
            while vi < self.count {
                new_values.push(self.values[vi])
                vi = vi + 1
            }
            new_values.push(v)
            return KVCache {
                keys: new_keys,
                values: new_values,
                count: self.count + 1,
                max_size: self.max_size
            }
        }
        return self
    }

    fn len(self) -> i64 = self.count

    fn is_full(self) -> bool = self.count >= self.max_size

    fn get(self, idx: i64) -> KVPair {
        if idx < 0 or idx >= self.count {
            return KVPair { key: Vec4::zeros(), value: Vec4::zeros() }
        }
        return KVPair {
            key: self.keys[idx],
            value: self.values[idx]
        }
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第五部分(2): LM Head — 词表概率输出 + 数值稳定 Softmax
-- ══════════════════════════════════════════════════════════════════

type LMHead {
    config: ModelConfig
    proj_scale: f64
    norm: RMSNormLayer
}

impl LMHead {
    fn create(cfg: ModelConfig) -> LMHead {
        return LMHead {
            config: cfg,
            proj_scale: 1.0,
            norm: RMSNormLayer::create(cfg.hidden_size, cfg.rms_eps)
        }
    }

    fn lm_apply(self, hidden: Vec4) -> [f64] {
        let normed = self.norm.norm_apply(hidden)
        let vocab_size = self.config.vocab_size
        let mut logits = []
        let mut vi = 0
        while vi < vocab_size {
            let seed = vi as f64
            let score = (normed.d0 * (1.0 + seed * 0.001)
                       + normed.d1 * (1.0 - seed * 0.0005)
                       + normed.d2 * (0.5 + seed * 0.0003)
                       + normed.d3 * (0.5 - seed * 0.0002))
                       * self.proj_scale
            logits.push(score)
            vi = vi + 1
        }
        return logits
    }
}

-- 数值稳定 Softmax
pub fn stable_softmax(logits: [f64]) -> [f64] {
    let n = logits.len()
    if n == 0 { return [] }

    let mut max_val = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > max_val { max_val = logits[i] }
        i = i + 1
    }

    let mut exp_vals = []
    let mut sum_exp = 0.0
    let mut ei = 0
    while ei < n {
        let e = math::exp(logits[ei] - max_val)
        exp_vals.push(e)
        sum_exp = sum_exp + e
        ei = ei + 1
    }

    if sum_exp < 0.0000000001 { sum_exp = 0.0000000001 }

    let mut result = []
    let mut ri = 0
    while ri < n {
        result.push(exp_vals[ri] / sum_exp)
        ri = ri + 1
    }
    return result
}

-- ══════════════════════════════════════════════════════════════════
-- 第五部分(3): 文本采样器 — Temperature / Top-K / Top-P / Rep Penalty
-- ══════════════════════════════════════════════════════════════════

type SamplerConfig {
    temperature: f64
    top_k: i64
    top_p: f64
    repetition_penalty: f64
}

impl SamplerConfig {
    fn default() -> SamplerConfig {
        return SamplerConfig { temperature: 0.8, top_k: 40, top_p: 0.9, repetition_penalty: 1.0 }
    }

    fn greedy() -> SamplerConfig {
        return SamplerConfig { temperature: 0.01, top_k: 1, top_p: 0.0, repetition_penalty: 1.0 }
    }

    fn creative() -> SamplerConfig {
        return SamplerConfig { temperature: 1.2, top_k: 80, top_p: 0.95, repetition_penalty: 1.1 }
    }

    fn info(self) -> str {
        return "T=" ++ self.temperature.to_str() ++
               " | K=" ++ self.top_k.to_str() ++
               " | P=" ++ self.top_p.to_str() ++
               " | rep_pen=" ++ self.repetition_penalty.to_str()
    }
}

type SampleResult {
    token_id: i64
    prob: f64
    top_prob: f64
    top_token: i64
    entropy: f64
}

type Sampler {
    config: SamplerConfig
}

impl Sampler {
    fn create(cfg: SamplerConfig) -> Sampler {
        return Sampler { config: cfg }
    }

    fn create_default() -> Sampler = Sampler::create(SamplerConfig::default())
    fn create_greedy() -> Sampler = Sampler::create(SamplerConfig::greedy())
    fn create_creative() -> Sampler = Sampler::create(SamplerConfig::creative())

    fn sample(self, logits: [f64], generated_ids: [i64]) -> SampleResult {
        let n = logits.len()
        if n == 0 {
            return SampleResult { token_id: 0, prob: 0.0, top_prob: 0.0, top_token: 0, entropy: 0.0 }
        }

        let adjusted = apply_rep_penalty(logits, generated_ids, self.config.repetition_penalty)

        let temp = self.config.temperature
        let mut scaled = []
        let mut i = 0
        while i < n {
            scaled.push(adjusted[i] / temp)
            i = i + 1
        }

        let probs = stable_softmax(scaled)
        let filtered = apply_top_k(probs, self.config.top_k)
        let final_probs = apply_top_p(filtered, self.config.top_p)

        let chosen = find_top_token(final_probs)
        let chosen_prob = final_probs[chosen]
        let top_token = find_top_token(probs)
        let top_prob = probs[top_token]
        let entropy = compute_entropy(probs)

        return SampleResult {
            token_id: chosen, prob: chosen_prob,
            top_prob: top_prob, top_token: top_token, entropy: entropy
        }
    }

    fn greedy_pick(self, logits: [f64]) -> SampleResult {
        let probs = stable_softmax(logits)
        let top_token = find_top_token(probs)
        let top_prob = probs[top_token]
        return SampleResult {
            token_id: top_token, prob: top_prob,
            top_prob: top_prob, top_token: top_token,
            entropy: compute_entropy(probs)
        }
    }
}

-- ── 采样辅助函数 ──

fn apply_rep_penalty(logits: [f64], generated_ids: [i64], penalty: f64) -> [f64] {
    let n = logits.len()
    let mut adjusted = []
    let mut ai = 0
    while ai < n {
        let val = logits[ai]
        let mut penalized = val
        let mut ri = 0
        while ri < generated_ids.len() {
            if generated_ids[ri] == ai {
                if val > 0.0 {
                    penalized = val / penalty
                } else {
                    penalized = val * penalty
                }
            }
            ri = ri + 1
        }
        adjusted.push(penalized)
        ai = ai + 1
    }
    return adjusted
}

fn remove_at_f64(arr: [f64], idx: i64) -> [f64] {
    let mut result = []
    let mut i = 0
    while i < arr.len() {
        if i != idx { result.push(arr[i]) }
        i = i + 1
    }
    return result
}

fn remove_at_i64(arr: [i64], idx: i64) -> [i64] {
    let mut result = []
    let mut i = 0
    while i < arr.len() {
        if i != idx { result.push(arr[i]) }
        i = i + 1
    }
    return result
}

fn normalize_f64(arr: [f64]) -> [f64] {
    let mut sum_r = 0.0
    let mut i = 0
    while i < arr.len() {
        sum_r = sum_r + arr[i]
        i = i + 1
    }
    if sum_r <= 0.0000000001 { return arr }
    let mut result = []
    let mut j = 0
    while j < arr.len() {
        result.push(arr[j] / sum_r)
        j = j + 1
    }
    return result
}

fn apply_top_k(probs: [f64], k: i64) -> [f64] {
    if k <= 0 or k >= probs.len() { return probs }

    let mut working = []
    let mut ci = 0
    while ci < probs.len() {
        working.push(probs[ci])
        ci = ci + 1
    }

    let mut threshold = 0.0
    let mut ki = 0
    while ki < k {
        let mut best_val = working[0]
        let mut bi = 0
        let mut j = 1
        while j < working.len() {
            if working[j] > best_val {
                best_val = working[j]
                bi = j
            }
            j = j + 1
        }
        threshold = best_val
        working = remove_at_f64(working, bi)
        ki = ki + 1
    }

    let mut result = []
    let mut fi = 0
    while fi < probs.len() {
        if probs[fi] >= threshold {
            result.push(probs[fi])
        } else {
            result.push(0.0)
        }
        fi = fi + 1
    }
    return normalize_f64(result)
}

fn apply_top_p(probs: [f64], p_threshold: f64) -> [f64] {
    if p_threshold <= 0.0 or p_threshold >= 1.0 { return probs }

    let n = probs.len()
    let mut indices = []
    let mut ii = 0
    while ii < n {
        indices.push(ii)
        ii = ii + 1
    }

    let sorted = sort_indices_desc(indices, probs)

    let mut cum_prob = 0.0
    let mut cutoff_idx = 0
    let mut pi = 0
    while pi < sorted.len() {
        cum_prob = cum_prob + probs[sorted[pi]]
        cutoff_idx = cutoff_idx + 1
        if cum_prob >= p_threshold {
            pi = sorted.len()
        }
        pi = pi + 1
    }

    let mut result = []
    let mut ri = 0
    while ri < n {
        result.push(0.0)
        ri = ri + 1
    }

    let mut ki = 0
    while ki < cutoff_idx {
        let target = sorted[ki]
        let mut new_result = []
        let mut ni = 0
        while ni < result.len() {
            if ni == target {
                new_result.push(probs[target])
            } else {
                new_result.push(result[ni])
            }
            ni = ni + 1
        }
        result = new_result
        ki = ki + 1
    }

    return normalize_f64(result)
}

fn sort_indices_desc(indices: [i64], probs: [f64]) -> [i64] {
    let mut result = []
    let mut remaining = indices
    while remaining.len() > 0 {
        let mut best_j = 0
        let mut best_val = probs[remaining[0]]
        let mut j = 1
        while j < remaining.len() {
            if probs[remaining[j]] > best_val {
                best_val = probs[remaining[j]]
                best_j = j
            }
            j = j + 1
        }
        result.push(remaining[best_j])
        remaining = remove_at_i64(remaining, best_j)
    }
    return result
}

pub fn find_top_token(probs: [f64]) -> i64 {
    let mut best_idx = 0
    let mut best_val = probs[0]
    let mut i = 1
    while i < probs.len() {
        if probs[i] > best_val {
            best_val = probs[i]
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

fn find_top_prob(probs: [f64]) -> f64 {
    let mut best = probs[0]
    let mut i = 1
    while i < probs.len() {
        if probs[i] > best { best = probs[i] }
        i = i + 1
    }
    return best
}

fn compute_entropy(probs: [f64]) -> f64 {
    let mut entropy = 0.0
    let mut i = 0
    while i < probs.len() {
        if probs[i] > 0.0000000001 {
            let lp = math::ln(probs[i])
            entropy = entropy - probs[i] * lp
        }
        i = i + 1
    }
    return entropy
}

