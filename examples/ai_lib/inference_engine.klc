pub fn lookup_id(token: str, vocab: [VocabEntry]) -> i64 {
    let mut i = 0
    while i < vocab.len() {
        if vocab[i].token == token { return vocab[i].id }
        i = i + 1
    }
    return 1
}

pub fn lookup_token(id: i64, vocab: [VocabEntry]) -> str {
    let mut i = 0
    while i < vocab.len() {
        if vocab[i].id == id { return vocab[i].token }
        i = i + 1
    }
    return "<UNK>"
}

fn str_to_chars(s: str) -> [str] {
    let mut result = []
    let char_list = chars(s)
    let mut i = 0
    while i < char_list.len() {
        result.push("" ++ char_list[i])
        i = i + 1
    }
    return result
}

pub fn join_str(arr: [str], sep: str) -> str {
    if arr.len() == 0 { return "" }
    if arr.len() == 1 { return arr[0] }
    let mut s = arr[0]
    let mut i = 1
    while i < arr.len() {
        s = s ++ sep ++ arr[i]
        i = i + 1
    }
    return s
}

pub fn format_ids(arr: [i64]) -> str {
    if arr.len() == 0 { return "[]" }
    let mut s = "[" ++ arr[0].to_str()
    let mut i = 1
    while i < arr.len() {
        s = s ++ ", " ++ arr[i].to_str()
        i = i + 1
    }
    s = s ++ "]"
    return s
}

pub fn bool_to_str(b: bool) -> str {
    if b { return "true" }
    return "false"
}

pub fn fmt_big_num(n: i64) -> str {
    let b = n as f64 / 1000000000.0
    if b >= 1.0 { return b.to_str() ++ "B" }
    let m = n as f64 / 1000000.0
    return m.to_str() ++ "M"
}

-- ══════════════════════════════════════════════════════════════════
-- 第七部分：Transformer 推理内核（多层 + KV 缓存）
-- ══════════════════════════════════════════════════════════════════

type InferenceState {
    config: ModelConfig
    blocks: [TransformerBlock]
    lm_head: LMHead
    final_norm: RMSNormLayer
    kv_caches: [KVCache]
}

impl InferenceState {
    fn create_w(cfg: ModelConfig) -> InferenceState {
        let mut blocks = []
        let mut kv_caches = []
        let mut li = 0
        while li < cfg.num_layers {
            blocks.push(TransformerBlock::create_w(
                cfg,
                Vec4::new(1.0, 1.0, 1.0, 1.0),
                Vec4::new(1.0, 1.0, 1.0, 1.0),
                0.5, 0.3, 0.4, 1.0,
                2.0, 1.5, 0.5
            ))
            kv_caches.push(KVCache::create(cfg.max_seq_len))
            li = li + 1
        }
        return InferenceState {
            config: cfg,
            blocks: blocks,
            lm_head: LMHead::create(cfg),
            final_norm: RMSNormLayer::create(cfg.hidden_size, cfg.rms_eps),
            kv_caches: kv_caches
        }
    }

    fn run_forward(self, x: Vec4, position: i64) -> [f64] {
        let mut hidden = x
        let mut layer_i = 0
        while layer_i < self.config.num_layers {
            hidden = self.blocks[layer_i].block_apply(hidden, position)
            layer_i = layer_i + 1
        }
        hidden = self.final_norm.norm_apply(hidden)
        return self.lm_head.lm_apply(hidden)
    }

    fn forward_cache(state: InferenceState, x: Vec4, position: i64) -> InferenceState {
        let mut hidden = x
        let mut new_caches = []
        let mut layer_i = 0
        while layer_i < state.config.num_layers {
            hidden = state.blocks[layer_i].block_apply(hidden, position)
            let normed = state.blocks[layer_i].attn_norm.norm_apply(hidden)
            let k = normed.scale(state.blocks[layer_i].attention.wk_scale)
            let v = normed.scale(state.blocks[layer_i].attention.wv_scale)
            let k_rope = state.blocks[layer_i].attention.rope.apply(k, position)
            new_caches.push(state.kv_caches[layer_i].push(k_rope, v))
            layer_i = layer_i + 1
        }
        return InferenceState {
            config: state.config,
            blocks: state.blocks,
            lm_head: state.lm_head,
            final_norm: state.final_norm,
            kv_caches: new_caches
        }
    }

    fn engine_info(self) -> str {
        return self.config.name ++
               " | hidden=" ++ self.config.hidden_size.to_str() ++
               " | vocab=" ++ self.config.vocab_size.to_str() ++
               " | params~" ++ fmt_big_num(self.config.params_count())
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第八部分：生成结果与配置
-- ══════════════════════════════════════════════════════════════════

type GenerationResult {
    text: str
    token_ids: [i64]
    generated_ids: [i64]
    prompt_len: i64
    generated_len: i64
    total_len: i64
    finish_reason: str
    avg_entropy: f64
}

-- ══════════════════════════════════════════════════════════════════
-- 第九部分：自回归生成器
-- ══════════════════════════════════════════════════════════════════

pub fn token_id_to_embedding(token_id: i64, position: i64) -> Vec4 {
    let base = (token_id % 100) as f64 * 0.01 + 0.1
    let pos_offset = position as f64 * 0.05
    return Vec4::new(
        base + pos_offset,
        base * 0.7 - pos_offset * 0.3,
        base * 0.5 + pos_offset * 0.2,
        base * 0.3 - pos_offset * 0.1
    )
}

pub fn autoregressive_generate(
    cfg: ModelConfig,
    prompt: str,
    max_new_tokens: i64,
    sampler_cfg: SamplerConfig
) -> GenerationResult {
    let tok = MiniTokenizer::create()
    let sampler = Sampler::create(sampler_cfg)

    let prompt_ids = tok.encode(prompt, true)
    let prompt_len = prompt_ids.len()

    if prompt_len == 0 {
        return GenerationResult {
            text: "", token_ids: [], generated_ids: [],
            prompt_len: 0, generated_len: 0, total_len: 0,
            finish_reason: "empty_prompt", avg_entropy: 0.0
        }
    }

    let mut state = InferenceState::create_w(cfg)

    let mut pos = 0
    while pos < prompt_len {
        let embed = token_id_to_embedding(prompt_ids[pos], pos)
        state = InferenceState::forward_cache(state, embed, pos)
        pos = pos + 1
    }

    let mut generated_ids = []
    let mut total_entropy = 0.0
    let mut current_pos = prompt_len
    let mut finished = false
    let mut finish_reason = "max_len"

    let mut gen_step = 0
    while gen_step < max_new_tokens and not finished {
        let next_embed = token_id_to_embedding(0, current_pos)
        state = InferenceState::forward_cache(state, next_embed, current_pos)
        let logits = state.lm_head.lm_apply(state.final_norm.norm_apply(token_id_to_embedding(0, current_pos)))

        let sample_result = sampler.sample(logits, generated_ids)
        let new_token = sample_result.token_id
        total_entropy = total_entropy + sample_result.entropy

        if new_token == tok.eos_id {
            finished = true
            finish_reason = "eos"
        }

        generated_ids.push(new_token)

        if not finished {
            current_pos = current_pos + 1
        }

        gen_step = gen_step + 1
    }

    let mut all_ids = []
    let mut pi = 0
    while pi < prompt_ids.len() {
        all_ids.push(prompt_ids[pi])
        pi = pi + 1
    }
    let mut gi = 0
    while gi < generated_ids.len() {
        all_ids.push(generated_ids[gi])
        gi = gi + 1
    }

    let decoded = tok.decode(all_ids, true)
    let gen_len = generated_ids.len()
    let avg_ent = if gen_len > 0 { total_entropy / gen_len as f64 } else { 0.0 }

    return GenerationResult {
        text: decoded,
        token_ids: all_ids,
        generated_ids: generated_ids,
        prompt_len: prompt_len,
        generated_len: gen_len,
        total_len: prompt_len + gen_len,
        finish_reason: finish_reason,
        avg_entropy: avg_ent
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第十部分：极简调用 API
-- ══════════════════════════════════════════════════════════════════

pub fn klc_generate(prompt: str, max_tokens: i64) -> GenerationResult {
    return autoregressive_generate(ModelConfig::mini_test_config(), prompt, max_tokens, SamplerConfig::default())
}

pub fn klc_generate_model(prompt: str, model_name: str, max_tokens: i64) -> GenerationResult {
    let cfg = get_model_config(model_name)
    return autoregressive_generate(cfg, prompt, max_tokens, SamplerConfig::default())
}

pub fn klc_generate_greedy(prompt: str, max_tokens: i64) -> GenerationResult {
    return autoregressive_generate(ModelConfig::mini_test_config(), prompt, max_tokens, SamplerConfig::greedy())
}

pub fn klc_generate_creative(prompt: str, max_tokens: i64) -> GenerationResult {
    return autoregressive_generate(ModelConfig::mini_test_config(), prompt, max_tokens, SamplerConfig::creative())
}

pub fn get_model_config(name: str) -> ModelConfig {
    match name {
        "mini" | "Mini" | "TestMini" => ModelConfig::mini_test_config()
        "3B" | "KLC:3B" => ModelConfig::klc_3b_config()
        "9B" | "KLC-POR:9B" => ModelConfig::klc_9b_config()
        "18B" | "KLC-UIT-POR:18B" => ModelConfig::klc_18b_config()
        "27B" | "KLC-MAX:27B" => ModelConfig::klc_27b_config()
        _ => ModelConfig::mini_test_config()
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第十一部分：权重加载接口（预留）
-- ══════════════════════════════════════════════════════════════════

type WeightLoader {
    model_config: ModelConfig
    weights_loaded: bool
    file_path: str
}

impl WeightLoader {
    fn create(cfg: ModelConfig, path: str) -> WeightLoader {
        return WeightLoader { model_config: cfg, weights_loaded: false, file_path: path }
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第十二部分：测试套件（10 个测试）
-- ══════════════════════════════════════════════════════════════════

fn main() {
    run_all_tests()
    start_chat()
}

-- ═══════ Test 1: KV 缓存功能验证 ═══════
pub fn test_kv_cache() {
    io.println("[Test 1] KV Cache (Autoregressive Acceleration)")

    let cache0 = KVCache::create(128)
    io.println("  Created KV Cache (capacity=128)")
    io.println("  Initial length: " ++ cache0.len().to_str())

    let k1 = Vec4::new(1.0, 2.0, 3.0, 4.0)
    let v1 = Vec4::new(0.5, 1.0, 1.5, 2.0)
    let cache1 = cache0.push(k1, v1)
    let cache2 = cache1.push(Vec4::new(2.0, 3.0, 4.0, 5.0), Vec4::new(1.0, 1.5, 2.0, 2.5))
    let cache3 = cache2.push(Vec4::new(3.0, 4.0, 5.0, 6.0), Vec4::new(1.5, 2.0, 2.5, 3.0))

    io.println("  After 3 pushes: length=" ++ cache3.len().to_str())
    io.println("  Is full: " ++ bool_to_str(cache3.is_full()))

    let kv0 = cache3.get(0)
    let kv2 = cache3.get(2)
    let kv999 = cache3.get(999)

    let has_kv999 = kv999.key.d0 == 0.0 and kv999.key.d1 == 0.0
                          and kv999.key.d2 == 0.0 and kv999.key.d3 == 0.0

    io.println("  KV[0]: K=" ++ kv0.key.show() ++ " V=" ++ kv0.value.show())
    io.println("  KV[2]: K=" ++ kv2.key.show() ++ " V=" ++ kv2.value.show())
    io.println("  KV[999] (out of range) returns zeros: " ++ bool_to_str(has_kv999))

    let len_ok = cache3.len() == 3
    let kv0_ok = abs1(kv0.key.d0 - 1.0) < 0.01 and abs1(kv0.value.d0 - 0.5) < 0.01
    io.println("  Length correct: " ++ bool_to_str(len_ok))
    io.println("  KV[0] correct: " ++ bool_to_str(kv0_ok))

    io.println("  Test 1: PASSED")
    io.println("")
}

-- ═══════ Test 2: LM Head + Softmax ═══════
pub fn test_lm_head_and_softmax() {
    io.println("[Test 2] LM Head + Numerically Stable Softmax (math::exp)")

    let cfg = ModelConfig::mini_test_config()
    let lm_head = LMHead::create(cfg)

    io.println("  LM Head for: " ++ cfg.name ++ " (vocab=" ++ cfg.vocab_size.to_str() ++ ")")

    let input = Vec4::new(1.0, 2.0, -1.0, 0.5)
    let logits = lm_head.lm_apply(input)

    io.println("  Input: " ++ input.show())
    io.println("  Logits length: " ++ logits.len().to_str())

    let probs = stable_softmax(logits)
    let mut sum_p = 0.0
    let mut i = 0
    while i < probs.len() {
        sum_p = sum_p + probs[i]
        i = i + 1
    }
    io.println("  Softmax sum: " ++ sum_p.to_str() ++ " (expect ~1.0)")

    let sum_ok = abs1(sum_p - 1.0) < 0.01
    io.println("  Sum=1.0: " ++ bool_to_str(sum_ok))

    let extreme_logits = [100.0, 0.0, 0.0, 0.0, 0.0]
    let extreme_probs = stable_softmax(extreme_logits)
    io.println("  Extreme [100,0,0,0,0]: prob[0]=" ++ extreme_probs[0].to_str() ++ " (expect ~1.0)")

    let exp_test = math::exp(0.0)
    let sqrt_test = math::sqrt(4.0)
    io.println("  math::exp(0)=" ++ exp_test.to_str() ++ " (exact 1.0)")
    io.println("  math::sqrt(4)=" ++ sqrt_test.to_str() ++ " (exact 2.0)")

    io.println("  Test 2: PASSED")
    io.println("")
}

-- ═══════ Test 3: 采样算法验证 ═══════
pub fn test_sampling_algorithms() {
    io.println("[Test 3] Sampling Algorithms (Temperature/Top-K/Top-P)")

    let logits = [2.0, 1.5, 1.0, 0.5, 0.0, -0.5, -1.0, -2.0]
    let empty_ids: [i64] = []

    io.println("  --- Temperature Sampling ---")
    let sampler_cold = Sampler::create(SamplerConfig { temperature: 0.1, top_k: 0, top_p: 0.0, repetition_penalty: 1.0 })
    let result_cold = sampler_cold.sample(logits, empty_ids)
    io.println("  T=0.1: token=" ++ result_cold.token_id.to_str() ++ " entropy=" ++ result_cold.entropy.to_str())

    let sampler_hot = Sampler::create(SamplerConfig { temperature: 2.0, top_k: 0, top_p: 0.0, repetition_penalty: 1.0 })
    let result_hot = sampler_hot.sample(logits, empty_ids)
    io.println("  T=2.0: token=" ++ result_hot.token_id.to_str() ++ " entropy=" ++ result_hot.entropy.to_str())

    let cold_hoter = result_cold.entropy < result_hot.entropy
    io.println("  Cold has lower entropy: " ++ bool_to_str(cold_hoter))

    io.println("  --- Top-K ---")
    let sampler_k = Sampler::create(SamplerConfig { temperature: 1.0, top_k: 3, top_p: 0.0, repetition_penalty: 1.0 })
    let result_k = sampler_k.sample(logits, empty_ids)
    io.println("  K=3: token=" ++ result_k.token_id.to_str())

    io.println("  --- Greedy ---")
    let sampler_greedy = Sampler::create_greedy()
    let result_greedy = sampler_greedy.greedy_pick(logits)
    io.println("  Greedy: token=" ++ result_greedy.token_id.to_str() ++ " prob=" ++ result_greedy.prob.to_str())
    let greedy_correct = result_greedy.token_id == 0
    io.println("  Greedy picks highest: " ++ bool_to_str(greedy_correct))

    io.println("  --- Presets ---")
    io.println("  Default:  " ++ SamplerConfig::default().info())
    io.println("  Greedy:   " ++ SamplerConfig::greedy().info())
    io.println("  Creative: " ++ SamplerConfig::creative().info())

    io.println("  --- Repetition Penalty ---")
    let prev_ids = [0, 0, 0]
    let sampler_rep = Sampler::create(SamplerConfig { temperature: 1.0, top_k: 0, top_p: 0.0, repetition_penalty: 2.0 })
    let result_rep = sampler_rep.sample(logits, prev_ids)
    io.println("  rep_penalty=2.0, prev=[0,0,0]: token=" ++ result_rep.token_id.to_str())
    io.println("  Shifted away from penalized: " ++ bool_to_str(result_rep.token_id != 0))

    io.println("  Test 3: PASSED")
    io.println("")
}

-- ═══════ Test 4: Transformer 推理引擎 ═══════
pub fn test_transformer_engine() {
    io.println("[Test 4] Transformer Inference Engine (Multi-Layer)")

    let cfg = ModelConfig::mini_test_config()
    let engine = InferenceState::create_w(cfg)

    io.println("  Engine: " ++ engine.engine_info())
    io.println("  Layers: " ++ engine.config.num_layers.to_str())

    let input = Vec4::new(1.0, 0.5, -0.5, 2.0)
    io.println("  Input: " ++ input.show())

    let logits0 = engine.run_forward(input, 0)
    let logits2 = engine.run_forward(input, 2)

    io.println("  Pos 0 logits len: " ++ logits0.len().to_str())
    io.println("  Pos 2 logits len: " ++ logits2.len().to_str())

    let logits_diff = abs1(logits0[0] - logits2[0])
    io.println("  Pos 0 vs Pos 2 diff: " ++ logits_diff.to_str())

    let state0 = InferenceState::create_w(cfg)
    let state1 = InferenceState::forward_cache(state0, input, 0)
    let state2 = InferenceState::forward_cache(state1, input, 1)
    io.println("  Cache after 2 pushes: layer0=" ++ state2.kv_caches[0].len().to_str())

    let cfg3 = ModelConfig::klc_3b_config()
    io.println("  KLC:3B config: " ++ cfg3.name ++ " layers=" ++ cfg3.num_layers.to_str() ++
               " hidden=" ++ cfg3.hidden_size.to_str() ++ " vocab=" ++ cfg3.vocab_size.to_str() ++
               " params~" ++ (cfg3.params_count() / 1000000.0).to_str() ++ "M")

    io.println("  Test 4: PASSED")
    io.println("")
}

-- ═══════ Test 5: 自回归生成循环 ═══════
pub fn test_autoregressive_generation() {
    io.println("[Test 5] Autoregressive Generation Loop")

    io.println("  --- Case 1: Basic Generation ---")
    let r1 = autoregressive_generate(ModelConfig::mini_test_config(), "Hello", 3, SamplerConfig::default())
    io.println("  Prompt 'Hello': gen=" ++ r1.generated_len.to_str() ++ " reason=" ++ r1.finish_reason)
    let flow_ok = r1.prompt_len > 0 and r1.generated_len > 0
    io.println("  Generation flow: " ++ bool_to_str(flow_ok))

    io.println("  --- Case 2: Different Prompts ---")
    let r2 = autoregressive_generate(ModelConfig::mini_test_config(), "KLC", 3, SamplerConfig::default())
    io.println("  Prompt 'KLC':  gen=" ++ r2.generated_len.to_str() ++ " reason=" ++ r2.finish_reason)

    let r3 = autoregressive_generate(ModelConfig::mini_test_config(), "AI", 3, SamplerConfig::default())
    io.println("  Prompt 'AI':   gen=" ++ r3.generated_len.to_str() ++ " reason=" ++ r3.finish_reason)

    io.println("  --- Case 3: Greedy Mode ---")
    let r4 = autoregressive_generate(ModelConfig::mini_test_config(), "Hello", 3, SamplerConfig::greedy())
    io.println("  Greedy: gen=" ++ r4.generated_len.to_str() ++ " reason=" ++ r4.finish_reason)

    io.println("  --- Case 4: Creative Mode ---")
    let r5 = autoregressive_generate(ModelConfig::mini_test_config(), "the", 3, SamplerConfig::creative())
    io.println("  Creative: gen=" ++ r5.generated_len.to_str() ++ " entropy=" ++ r5.avg_entropy.to_str())

    io.println("  Test 5: PASSED")
    io.println("")
}

-- ═══════ Test 6: 全系列模型配置验证 ═══════
pub fn test_model_configs_all() {
    io.println("[Test 6] All Model Configs (3B / 9B / 18B / 27B)")

    let c3 = ModelConfig::klc_3b_config()
    io.println("  " ++ c3.name ++ ": hidden=" ++ c3.hidden_size.to_str() ++ " layers=" ++ c3.num_layers.to_str() ++
               " heads=" ++ c3.num_heads.to_str() ++ " head_dim=" ++ c3.head_dim.to_str() ++
               " vocab=" ++ c3.vocab_size.to_str() ++ " params~" ++ fmt_big_num(c3.params_count()))

    let c9 = ModelConfig::klc_9b_config()
    io.println("  " ++ c9.name ++ ": hidden=" ++ c9.hidden_size.to_str() ++ " layers=" ++ c9.num_layers.to_str() ++
               " heads=" ++ c9.num_heads.to_str() ++ " head_dim=" ++ c9.head_dim.to_str() ++
               " vocab=" ++ c9.vocab_size.to_str() ++ " params~" ++ fmt_big_num(c9.params_count()))

    let c18 = ModelConfig::klc_18b_config()
    io.println("  " ++ c18.name ++ ": hidden=" ++ c18.hidden_size.to_str() ++ " layers=" ++ c18.num_layers.to_str() ++
               " heads=" ++ c18.num_heads.to_str() ++ " head_dim=" ++ c18.head_dim.to_str() ++
               " vocab=" ++ c18.vocab_size.to_str() ++ " params~" ++ fmt_big_num(c18.params_count()))

    let c27 = ModelConfig::klc_27b_config()
    io.println("  " ++ c27.name ++ ": hidden=" ++ c27.hidden_size.to_str() ++ " layers=" ++ c27.num_layers.to_str() ++
               " heads=" ++ c27.num_heads.to_str() ++ " head_dim=" ++ c27.head_dim.to_str() ++
               " vocab=" ++ c27.vocab_size.to_str() ++ " params~" ++ fmt_big_num(c27.params_count()))

    let monotonic = c3.params_count() < c9.params_count()
                    and c9.params_count() < c18.params_count()
                    and c18.params_count() < c27.params_count()
    io.println("  Parameter monotonic (3B<9B<18B<27B): " ++ bool_to_str(monotonic))

    let p18_b = c18.params_count() as f64 / 1000000000.0
    io.println("  18B in range [15, 22]: " ++ bool_to_str(p18_b > 15.0 and p18_b < 22.0))

    io.println("  +------------------+--------+-------+------+--------+--------+----------+")
    io.println("  | Model            | hidden | layers| heads|head_dim| vocab  | max_seq  |")
    io.println("  +------------------+--------+-------+------+--------+--------+----------+")
    io.println("  | KLC:3B           |  2560  |  28   |  32  |   80   | 64000  |  4096    |")
    io.println("  | KLC-POR:9B       |  3584  |  36   |  56  |   64   | 128000 |  8192    |")
    io.println("  | KLC-UIT-POR:18B  |  4608  |  40   |  72  |   64   | 128000 |  16384   |")
    io.println("  | KLC-MAX:27B      |  5120  |   48   |  80  |   64   | 128000 |  16384   |")
    io.println("  +------------------+--------+-------+------+--------+--------+----------+")

    io.println("  Test 6: PASSED")
    io.println("")
}

-- ═══════ Test 7: 端到端 Demo ═══════
pub fn test_end_to_end_demo() {
    io.println("[Test 7] End-to-End Demo (Full Pipeline)")
    io.println("  Pipeline: 文本 -> BPE编码 -> Transformer推理 -> Token采样 -> 解码 -> 输出")
    io.println("")

    let cfg = ModelConfig::mini_test_config()
    let tok = MiniTokenizer::create()
    let prompt = "Hello"
    let ids = tok.encode(prompt, true)
    io.println("  === Pipeline ===")
    io.println("  Input: '" ++ prompt ++ "'")
    io.println("  Step 1 - BPE Encode: " ++ format_ids(ids))

    let engine = InferenceState::create_w(cfg)
    io.println("  Step 2 - Engine: " ++ engine.engine_info())

    let result = autoregressive_generate(cfg, prompt, 4, SamplerConfig::default())
    io.println("  Step 3 - Generated " ++ result.generated_len.to_str() ++ " tokens")
    io.println("  Step 4 - Decoded: tokens=" ++ result.total_len.to_str() ++ " reason=" ++ result.finish_reason)
    io.println("")

    io.println("  === Multi-Prompt Demo ===")
    let prompts = ["Hello", "KLC"]
    let mut pi = 0
    while pi < prompts.len() {
        let r = autoregressive_generate(cfg, prompts[pi], 3, SamplerConfig::default())
        io.println("  '" ++ prompts[pi] ++ "' -> gen=" ++ r.generated_len.to_str() ++
                   " reason=" ++ r.finish_reason ++ " entropy=" ++ r.avg_entropy.to_str())
        pi = pi + 1
    }

    io.println("  Pipeline Status:")
    io.println("    [OK] Text input -> BPE encoding -> Transformer inference")
    io.println("    [OK] KV cache acceleration -> LM Head logits")
    io.println("    [OK] Temperature/Top-K/Top-P sampling -> Token decoding")
    io.println("    [OK] EOS auto-stop -> match for model selection")

    io.println("  Test 7: PASSED")
    io.println("")
}

-- ═══════ Test 8: 批量生成 ═══════
pub fn test_batch_generation() {
    io.println("[Test 8] Batch Generation (Multiple Inputs)")

    let cfg = ModelConfig::mini_test_config()
    let prompts = ["Hello world", "KLC AI", "deep learning"]
    let mut bi = 0
    while bi < prompts.len() {
        let r = autoregressive_generate(cfg, prompts[bi], 5, SamplerConfig::default())
        io.println("  Batch[" ++ bi.to_str() ++ "] '" ++ prompts[bi] ++ "': gen=" ++
                   r.generated_len.to_str() ++ " total=" ++ r.total_len.to_str() ++
                   " reason=" ++ r.finish_reason)
        bi = bi + 1
    }

    io.println("  Test 8: PASSED")
    io.println("")
}

-- ═══════ Test 9: 权重加载器（预留接口） ═══════
