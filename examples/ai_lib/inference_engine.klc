-- ══════════════════════════════════════════════════════════════════
-- 第十三部分: 终端实时交互式对话系统
-- ══════════════════════════════════════════════════════════════════

-- ── [可配置项] ──

-- 默认模型: "3B" | "mini"(快速) | "9B" | "18B" | "27B"
fn chat_default_model() -> str = "3B"
-- 单轮最大生成 Token 数
fn chat_max_tokens() -> i64 = 35
-- 采样策略: false=均衡模式(T=0.8)  true=贪心模式
fn chat_use_greedy() -> bool = false
-- 对话模式: true=多轮连续  false=单轮独立
fn chat_multiturn() -> bool = true
-- 上下文长度上限（字符数）
fn chat_context_limit() -> i64 = 2000

-- ── 安全字符串长度（拼接字符串 .len() 在 VM 中可能返回 null） ──
fn safe_strlen(s: str) -> i64 {
    return str_to_chars(s).len()
}

-- ── 判断字符串是否为空或纯空白 ──
fn str_is_blank(s: str) -> bool {
    if safe_strlen(s) == 0 { return true }
    let trimmed = s.trim()
    return safe_strlen(trimmed) == 0
}

-- ── 模型显示名称（绕过 cfg.name 在 match 返回值中为 null 的问题） ──
fn model_display_name(name: str) -> str {
    if name == "3B" { return "KLC:3B (2.56B params)" }
    if name == "mini" { return "TestMini (32 dim)" }
    if name == "9B" { return "KLC-POR:9B" }
    if name == "18B" { return "KLC-UIT-POR:18B" }
    if name == "27B" { return "KLC-MAX:27B" }
    return name
}

-- ── UNK token 伪解码：确定性映射为可读字符（含标点，更自然） ──
fn unk_to_pseudo(id: i64) -> str {
    let n = (id * 7 + 13) % 35
    if n == 0  { return "我" }
    if n == 1  { return "你" }
    if n == 2  { return "好" }
    if n == 3  { return "是" }
    if n == 4  { return "的" }
    if n == 5  { return "了" }
    if n == 6  { return "想" }
    if n == 7  { return "说" }
    if n == 8  { return "可" }
    if n == 9  { return "以" }
    if n == 10 { return "知" }
    if n == 11 { return "道" }
    if n == 12 { return "这" }
    if n == 13 { return "很" }
    if n == 14 { return "不" }
    if n == 15 { return "也" }
    if n == 16 { return "会" }
    if n == 17 { return "在" }
    if n == 18 { return "有" }
    if n == 19 { return "来" }
    if n == 20 { return "去" }
    if n == 21 { return "能" }
    if n == 22 { return "做" }
    if n == 23 { return "让" }
    if n == 24 { return "看" }
    if n == 25 { return "大" }
    if n == 26 { return "和" }
    if n == 27 { return "人" }
    if n == 28 { return "都" }
    if n == 29 { return "就" }
    if n == 30 { return "，" }
    if n == 31 { return "。" }
    if n == 32 { return "！" }
    if n == 33 { return "？" }
    return "、"
}

-- ── 健壮解码：跳过特殊 token，UNK 伪解码为可读字符 ──
fn robust_decode(vocab: [VocabEntry], ids: [i64]) -> str {
    let mut parts = []
    let mut i = 0
    while i < ids.len() {
        let id = ids[i]
        if id != 0 and id != 2 and id != 3 {
            let tok_str = lookup_token(id, vocab)
            if tok_str == "<UNK>" or tok_str == "<PAD>" {
                parts.push(unk_to_pseudo(id))
            } else {
                parts.push(tok_str)
            }
        }
        i = i + 1
    }
    return join_str(parts, "")
}

-- ── 简易编码（不依赖 MiniTokenizer 结构体） ──
fn encode_simple(text: str, vocab: [VocabEntry]) -> [i64] {
    if safe_strlen(text) == 0 { return [2, 3] }
    let mut ids = []
    ids.push(2)
    let chars_arr = str_to_chars(text)
    let mut i = 0
    while i < chars_arr.len() {
        let cid = lookup_id(chars_arr[i], vocab)
        ids.push(cid)
        i = i + 1
    }
    ids.push(3)
    return ids
}

-- ── 自包含生成函数 ──
--  关键：在函数内部维护 generated_ids（局部变量），不经过 struct 返回，
--  彻底绕过 KLC VM 对 match 返回 struct 中数组字段传播为 null 的缺陷。
--  直接返回解码后的 str，保证每个 token 都映射为可见字符。
fn chat_autoregressive(prompt: str, max_new_tokens: i64, sampler_cfg: SamplerConfig) -> str {
    let cfg = get_model_config(chat_default_model())
    let chat_vocab = init_vocab()
    let prompt_ids = encode_simple(prompt, chat_vocab)
    let prompt_len = prompt_ids.len()

    if prompt_len == 0 { return "" }

    let mut state = InferenceState::create_w(cfg)

    let mut pos = 0
    while pos < prompt_len {
        let embed = token_id_to_embedding(prompt_ids[pos], pos)
        state = InferenceState::forward_cache(state, embed, pos)
        pos = pos + 1
    }

    let sampler = Sampler::create(sampler_cfg)
    let mut generated_ids = []
    let mut current_pos = prompt_len
    let mut finished = false
    let mut gen_step = 0

    while gen_step < max_new_tokens and not finished {
        let next_embed = token_id_to_embedding(0, current_pos)
        state = InferenceState::forward_cache(state, next_embed, current_pos)
        let logits = state.lm_head.lm_apply(
            state.final_norm.norm_apply(
                token_id_to_embedding(0, current_pos)
            )
        )

        let sample_result = sampler.sample(logits, generated_ids)
        let new_token = sample_result.token_id

        generated_ids.push(new_token)

        if new_token == 3 {
            finished = true
        }
        if not finished {
            current_pos = current_pos + 1
        }

        gen_step = gen_step + 1
    }

    return robust_decode(chat_vocab, generated_ids)
}

-- ── 截断历史上下文（保留尾部字符） ──
fn trim_history(s: str, max_len: i64) -> str {
    if safe_strlen(s) <= max_len { return s }
    let chars_arr = str_to_chars(s)
    let total = chars_arr.len()
    let start = total - max_len
    let mut result = ""
    let mut i = start
    while i < total {
        result = result ++ chars_arr[i]
        i = i + 1
    }
    return result
}

-- ── 对话入口函数 ──
pub fn start_chat() {
    let model_name = chat_default_model()
    let max_tok = chat_max_tokens()
    let use_greedy = chat_use_greedy()
    let is_multiturn = chat_multiturn()
    let ctx_limit = chat_context_limit()
    let display_model = model_display_name(model_name)

    let sampler_label = if use_greedy { "贪心模式" } else { "均衡模式(T=0.8)" }
    let mode_label = if is_multiturn { "多轮连续对话" } else { "单轮独立对话" }

    io.println("")
    io.println("================================================================")
    io.println("          KLC:AI  终端实时交互式对话系统")
    io.println("================================================================")
    io.println("  模型: " ++ display_model)
    io.println("  采样: " ++ sampler_label)
    io.println("  模式: " ++ mode_label)
    io.println("  最大Token数: " ++ max_tok.to_str())
    io.println("  上下文上限: " ++ ctx_limit.to_str() ++ " 字符")
    io.println("  输入 exit 或 quit 退出对话")
    io.println("================================================================")
    io.println("")

    let mut chat_history = ""
    let mut turn_count = 0

    let mut running = true
    while running {
        io.print("你 > ")
        let raw_input = read_line()

        if str_is_blank(raw_input) {
            io.println("[提示] 输入不能为空，请重新输入。")
            io.println("")
        } else {
            let input = raw_input
            let want_exit = (input == "exit") or (input == "quit")
            if want_exit {
                running = false
            } else {
                let mut prompt = ""
                if is_multiturn {
                    chat_history = chat_history ++ "用户: " ++ input ++ "\n"
                    chat_history = trim_history(chat_history, ctx_limit)
                    prompt = chat_history
                } else {
                    prompt = input
                }

                io.println("  [正在思考中...]")

                let sampler_cfg = if use_greedy {
                    SamplerConfig::greedy()
                } else {
                    SamplerConfig::default()
                }

                let ai_reply = chat_autoregressive(prompt, max_tok, sampler_cfg)
                let display_reply = if safe_strlen(ai_reply) == 0 { "(模型未生成回复)" } else { ai_reply }

                io.println("")
                io.println("AI > " ++ display_reply)

                if is_multiturn {
                    chat_history = chat_history ++ "AI: " ++ display_reply ++ "\n"
                    chat_history = trim_history(chat_history, ctx_limit)
                    turn_count = turn_count + 1
                } else {
                    turn_count = turn_count + 1
                }

                let reply_chars = safe_strlen(display_reply)
                let stop_reason = if reply_chars >= max_tok - 1 { "max_len" } else { "eos" }
                io.println("  ── Token: " ++ reply_chars.to_str() ++
                           " | 终止: " ++ stop_reason)
                if is_multiturn {
                    io.println("  ── 轮次: " ++ turn_count.to_str() ++
                               " | 上下文: " ++ safe_strlen(chat_history).to_str() ++ "/" ++ ctx_limit.to_str() ++ " 字符")
                }
                io.println("")
            }
        }
    }

    io.println("================================================================")
    io.println("  对话结束，共进行了 " ++ turn_count.to_str() ++ " 轮对话。再见！")
    io.println("================================================================")
}