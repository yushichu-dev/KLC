    io.println("[Test 9] Weight Loader (.klcw Interface, Reserved)")

    let cfg = ModelConfig::mini_test_config()
    let loader = WeightLoader::create(cfg, "model_weights.klcw")
    io.println("  Loader for: " ++ loader.file_path)
    io.println("  Loaded: " ++ bool_to_str(loader.weights_loaded))

    io.println("  Test 9: PASSED")
    io.println("")
}

-- ═══════ Test 10: 极简 API 验证 ═══════
pub fn test_simple_api() {
    io.println("[Test 10] Simple API (One-Line Generation)")

    let r1 = klc_generate("Hello", 3)
    io.println("  klc_generate('Hello', 3): gen=" ++ r1.generated_len.to_str() ++ " reason=" ++ r1.finish_reason)

    let r2 = klc_generate_model("KLC is", "3B", 6)
    io.println("  klc_generate_model('KLC is', '3B', 6): gen=" ++ r2.generated_len.to_str() ++ " reason=" ++ r2.finish_reason)

    let r3 = klc_generate_model("AI", "27B", 4)
    io.println("  klc_generate_model('AI', '27B', 4): gen=" ++ r3.generated_len.to_str() ++ " reason=" ++ r3.finish_reason)

    let r4 = klc_generate_greedy("Hello", 5)
    io.println("  klc_generate_greedy('Hello', 5): gen=" ++ r4.generated_len.to_str() ++ " reason=" ++ r4.finish_reason)

    let r5 = klc_generate_creative("the", 10)
    io.println("  klc_generate_creative('the', 10): gen=" ++ r5.generated_len.to_str() ++ " entropy=" ++ r5.avg_entropy.to_str())

    let api_ok = r1.generated_len > 0 and r2.generated_len > 0 and r3.generated_len > 0
    io.println("  All API calls successful: " ++ bool_to_str(api_ok))

    io.println("  Quick Reference:")
    io.println("    klc_generate(prompt, max_tokens)")
    io.println("    klc_generate_model(prompt, model, max_tokens)")
    io.println("    klc_generate_greedy(prompt, max_tokens)")
    io.println("    klc_generate_creative(prompt, max_tokens)")

    io.println("  Test 10: PASSED")
    io.println("")
}

