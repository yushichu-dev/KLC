-- ============================================================================
-- KLC:AI BPE Tokenizer v2.0 - AI底座第二阶段
-- 基于 KLC v0.7.3 语法限制实现
--
-- 核心模块：
--   1. BPE 分词器（Byte-Pair Encoding）— 完整编码/解码
--   2. 文本预处理（空格归一化、标点分割、大小写保留）
--   3. 编码管道：字符串 → Token ID 序列
--   4. 解码管道：ID 序列 → 可读文本
--   5. 特殊 Token 管理（BOS/EOS/PAD/UNK/MASK）
--   6. 多模型适配（KLC:3B / KLC-POR:9B / KLC-MAX:27B）
--
-- BPE 算法原理：
--   1. 将文本拆分为单词（预分词）
--   2. 对每个单词，拆分为字符序列
--   3. 迭代合并频率最高的相邻 token 对
--   4. 合并优先级由 rank 决定（越小越先合并）
--   5. 无法继续合并时，查找词表获得 Token ID
--
-- 语法约束（严格遵循）：
--   - 无内置数学库 (math.xxx)
--   - if语句内不使用let绑定
--   - 关联函数: 类型::函数名()
--   - 不使用pub关键字
--   - 浮点输出: to_str()
--   - 循环优先使用while（for循环数组索引不稳定）
--   - 无字典类型，使用数组 + 线性查找
--   - 无正则引擎，使用字符级匹配
-- ============================================================================

mod tokenizer

-- ══════════════════════════════════════════════════════════════════
-- 第一部分：基础数据结构
-- ══════════════════════════════════════════════════════════════════

-- 词表条目：token 文本 <-> ID 映射单元
-- KLC 无原生 dict，使用数组 + 线性查找
type VocabEntry {
    token: str       -- token 字符串
    id: i64          -- 唯一 ID
}

-- BPE 合并规则：相邻 token 对的合并优先级
-- rank 越小 = 优先级越高 = 越早执行合并
type BPEMerge {
    left: str        -- 左侧 token
    right: str       -- 右侧 token
    rank: i64        -- 合并优先级
}

-- 特殊 Token 定义
type SpecialTokenDef {
    name: str        -- 名称标识（如 "BOS", "EOS"）
    id: i64          -- Token ID
    value: str       -- 文本表示（解码时使用）
}

-- 编码输出（包含完整信息）
type EncodeOutput {
    ids: [i64]       -- Token ID 序列
    tokens: [str]    -- Token 文本序列
    count: i64       -- Token 总数
}

-- 模型配置档案（与 transformer_core.klc 的 ModelConfig 对齐）
-- 存储每个模型规格的关键参数，供分词器验证和适配
type ModelProfile {
    name: str                -- 模型名称标识
    hidden_size: i64         -- 隐藏层维度（嵌入矩阵宽度）
    num_layers: i64          -- Transformer 层数
    num_heads: i64           -- 注意力头数量
    head_dim: i64            -- 每个头的维度
    intermediate_size: i64   -- FFN 中间层大小
    vocab_size: i64          -- 词表大小
    max_seq_len: i64         -- 最大序列长度（对齐 RoPE）
    rope_theta: f64          -- RoPE 基频
    rms_eps: f64             -- RMSNorm epsilon
}

-- 注意力掩码（标记有效 token 和填充位置）
-- 用于 Transformer 的注意力计算：1=attend, 0=ignore
type AttentionMask {
    mask: [i64]       -- 掩码值序列（0 或 1）
    valid_len: i64    -- 有效（非填充）token 数量
    total_len: i64    -- 总长度（含填充）
}

-- 模型输入封装（完整的 Transformer 输入格式）
-- 包含 token ID、注意力掩码、位置信息
type ModelInput {
    token_ids: [i64]        -- Token ID 序列（含 BOS/EOS）
    attention_mask: [i64]   -- 注意力掩码
    seq_len: i64            -- 有效序列长度
    total_len: i64          -- 填充后总长度
    has_bos: bool           -- 是否包含 BOS
    has_eos: bool           -- 是否包含 EOS
}

-- ══════════════════════════════════════════════════════════════════
-- 第二部分：BPE 分词器主类型
-- ══════════════════════════════════════════════════════════════════
--
-- 存储词表、合并规则和特殊符号。
-- 适配 KLC 全系列模型：3B(2560) / 9B(3584) / 27B(5120)。
-- 支持最长序列 16384（对齐 RoPE 最大长度）。
--
-- 设计说明：
--   - 使用 [VocabEntry] 数组代替 hash map
--   - 查找复杂度 O(n)，适合演示和中小词表（< 100K）
--   - 生产环境可通过 KLC FFI 替换为高效实现
type BPETokenizer {
    vocab: [VocabEntry]          -- 词表条目数组
    merges: [BPEMerge]           -- BPE 合并规则数组（按 rank 升序）
    specials: [SpecialTokenDef]  -- 特殊 token 定义数组

    -- 特殊 Token ID（快速访问，避免每次线性查找）
    bos_id: i64        -- 序列开始标记 (Beginning of Sequence)
    eos_id: i64        -- 序列结束标记 (End of Sequence)
    pad_id: i64        -- 填充标记 (Padding)
    unk_id: i64        -- 未知 token 标记 (Unknown)

    -- 模型适配参数
    vocab_size: i64              -- 词表大小
    max_seq_len: i64             -- 最大序列长度
    name: str                    -- 分词器/模型名称
    profile: ModelProfile        -- 完整模型配置档案
}

-- ══════════════════════════════════════════════════════════════════
-- 第三部分：BPE 分词器实现
-- ══════════════════════════════════════════════════════════════════

impl BPETokenizer {

    -- ═══════════ 构造函数 ═══════════

    -- 创建默认分词器（含演示词表和 BPE 规则）
    -- 适合开发和测试使用
    fn create_default() -> BPETokenizer {
        let profile = ModelProfile {
            name: "KLC-BPE-Default",
            hidden_size: 2560,
            num_layers: 28,
            num_heads: 32,
            head_dim: 80,
            intermediate_size: 6912,
            vocab_size: 64000,
            max_seq_len: 16384,
            rope_theta: 10000.0,
            rms_eps: 1e-6
        }

        let tok = BPETokenizer {
            vocab: [],
            merges: [],
            specials: [],
            bos_id: 2,
            eos_id: 3,
            pad_id: 0,
            unk_id: 1,
            vocab_size: 0,
            max_seq_len: 16384,
            name: "KLC-BPE-Default",
            profile: profile
        }

        tok.init_special_tokens()
        tok.init_base_vocab()
        tok.init_bpe_merges()
        tok.vocab_size = tok.vocab.len()

        return tok
    }

    -- 创建适配 KLC:3B 的分词器
    -- hidden_size: 2560, vocab: 64000, max_seq: 4096
    -- 28 层, 32 头, head_dim=80, RoPE theta=10000
    fn create_klc_3b() -> BPETokenizer {
        let tok = BPETokenizer::create_default()
        tok.name = "KLC:3B-BPE"
        tok.max_seq_len = 4096
        tok.profile = ModelProfile {
            name: "KLC:3B",
            hidden_size: 2560,
            num_layers: 28,
            num_heads: 32,
            head_dim: 80,
            intermediate_size: 6912,
            vocab_size: 64000,
            max_seq_len: 4096,
            rope_theta: 10000.0,
            rms_eps: 1e-6
        }
        return tok
    }

    -- 创建适配 KLC-POR:9B 的分词器
    -- hidden_size: 3584, vocab: 128000, max_seq: 8192
    -- 36 层, 56 头, head_dim=64, RoPE theta=1000000
    fn create_klc_9b() -> BPETokenizer {
        let tok = BPETokenizer::create_default()
        tok.name = "KLC-POR:9B-BPE"
        tok.max_seq_len = 8192
        tok.profile = ModelProfile {
            name: "KLC-POR:9B",
            hidden_size: 3584,
            num_layers: 36,
            num_heads: 56,
            head_dim: 64,
            intermediate_size: 18944,
            vocab_size: 128000,
            max_seq_len: 8192,
            rope_theta: 1000000.0,
            rms_eps: 1e-5
        }
        return tok
    }

    -- 创建适配 KLC-MAX:27B 的分词器
    -- hidden_size: 5120, vocab: 128000, max_seq: 16384
    -- 48 层, 80 头, head_dim=64, RoPE theta=1000000
    fn create_klc_27b() -> BPETokenizer {
        let tok = BPETokenizer::create_default()
        tok.name = "KLC-MAX:27B-BPE"
        tok.max_seq_len = 16384
        tok.profile = ModelProfile {
            name: "KLC-MAX:27B",
            hidden_size: 5120,
            num_layers: 48,
            num_heads: 80,
            head_dim: 64,
            intermediate_size: 27648,
            vocab_size: 128000,
            max_seq_len: 16384,
            rope_theta: 1000000.0,
            rms_eps: 1e-5
        }
        return tok
    }

    -- ═══════════ 初始化方法 ═══════════

    -- 初始化特殊 token 定义（8 个标准特殊 token）
    fn init_special_tokens(self mut) {
        self.specials.push(SpecialTokenDef { name: "PAD",  id: 0, value: "" })
        self.specials.push(SpecialTokenDef { name: "UNK",  id: 1, value: "" })
        self.specials.push(SpecialTokenDef { name: "BOS",  id: 2, value: "" })
        self.specials.push(SpecialTokenDef { name: "EOS",  id: 3, value: "" })
        self.specials.push(SpecialTokenDef { name: "MASK", id: 4, value: "" })
        self.specials.push(SpecialTokenDef { name: "SEP",  id: 5, value: "" })
        self.specials.push(SpecialTokenDef { name: "CLS",  id: 6, value: "" })
        self.specials.push(SpecialTokenDef { name: "NL",   id: 7, value: "\n" })
    }

    -- 初始化基础演示词表
    --
    -- 词表 ID 分配：
    --   0-7:   特殊 token（<PAD>, <UNK>, <BOS>, <EOS>, ...）
    --   8-10:  控制字符（空格, 换行, 制表符）
    --   11-20: 标点符号
    --   30-98: 高频英文单词 + KLC/AI 专用词汇
    --   200-275: 单个 ASCII 字符（a-z, A-Z, 0-9）
    --   300-319: 常见子词（BPE 合并中间结果）
    fn init_base_vocab(self mut) {
        -- 特殊 token
        self.vocab.push(VocabEntry { token: "<PAD>",  id: 0 })
        self.vocab.push(VocabEntry { token: "<UNK>",  id: 1 })
        self.vocab.push(VocabEntry { token: "<BOS>",  id: 2 })
        self.vocab.push(VocabEntry { token: "<EOS>",  id: 3 })
        self.vocab.push(VocabEntry { token: "<MASK>", id: 4 })
        self.vocab.push(VocabEntry { token: "<SEP>",  id: 5 })
        self.vocab.push(VocabEntry { token: "<CLS>",  id: 6 })
        self.vocab.push(VocabEntry { token: "<NL>",   id: 7 })

        -- 控制字符
        self.vocab.push(VocabEntry { token: " ",  id: 8 })
        self.vocab.push(VocabEntry { token: "\n", id: 9 })
        self.vocab.push(VocabEntry { token: "\t", id: 10 })

        -- 标点符号
        self.vocab.push(VocabEntry { token: ",",  id: 11 })
        self.vocab.push(VocabEntry { token: ".",  id: 12 })
        self.vocab.push(VocabEntry { token: "!",  id: 13 })
        self.vocab.push(VocabEntry { token: "?",  id: 14 })
        self.vocab.push(VocabEntry { token: ";",  id: 15 })
        self.vocab.push(VocabEntry { token: ":",  id: 16 })
        self.vocab.push(VocabEntry { token: "\"", id: 17 })
        self.vocab.push(VocabEntry { token: "'",  id: 18 })
        self.vocab.push(VocabEntry { token: "(",  id: 19 })
        self.vocab.push(VocabEntry { token: ")",  id: 20 })
        self.vocab.push(VocabEntry { token: "-",  id: 21 })
        self.vocab.push(VocabEntry { token: "_",  id: 22 })

        -- 高频英文单词
        self.vocab.push(VocabEntry { token: "the",    id: 30 })
        self.vocab.push(VocabEntry { token: "is",     id: 31 })
        self.vocab.push(VocabEntry { token: "a",      id: 32 })
        self.vocab.push(VocabEntry { token: "and",    id: 33 })
        self.vocab.push(VocabEntry { token: "to",     id: 34 })
        self.vocab.push(VocabEntry { token: "of",     id: 35 })
        self.vocab.push(VocabEntry { token: "in",     id: 36 })
        self.vocab.push(VocabEntry { token: "for",    id: 37 })
        self.vocab.push(VocabEntry { token: "it",     id: 38 })
        self.vocab.push(VocabEntry { token: "on",     id: 39 })
        self.vocab.push(VocabEntry { token: "that",   id: 40 })
        self.vocab.push(VocabEntry { token: "with",   id: 41 })
        self.vocab.push(VocabEntry { token: "as",     id: 42 })
        self.vocab.push(VocabEntry { token: "are",    id: 43 })
        self.vocab.push(VocabEntry { token: "was",    id: 44 })
        self.vocab.push(VocabEntry { token: "at",     id: 45 })
        self.vocab.push(VocabEntry { token: "be",     id: 46 })
        self.vocab.push(VocabEntry { token: "this",   id: 47 })
        self.vocab.push(VocabEntry { token: "have",   id: 48 })
        self.vocab.push(VocabEntry { token: "from",   id: 49 })
        self.vocab.push(VocabEntry { token: "or",     id: 50 })
        self.vocab.push(VocabEntry { token: "an",     id: 51 })
        self.vocab.push(VocabEntry { token: "not",    id: 52 })
        self.vocab.push(VocabEntry { token: "but",    id: 53 })
        self.vocab.push(VocabEntry { token: "by",     id: 54 })
        self.vocab.push(VocabEntry { token: "do",     id: 55 })
        self.vocab.push(VocabEntry { token: "will",   id: 56 })
        self.vocab.push(VocabEntry { token: "can",    id: 57 })
        self.vocab.push(VocabEntry { token: "we",     id: 58 })
        self.vocab.push(VocabEntry { token: "they",   id: 59 })

        -- 代词和常见词
        self.vocab.push(VocabEntry { token: "I",      id: 60 })
        self.vocab.push(VocabEntry { token: "you",    id: 61 })
        self.vocab.push(VocabEntry { token: "he",     id: 62 })
        self.vocab.push(VocabEntry { token: "she",    id: 63 })
        self.vocab.push(VocabEntry { token: "my",     id: 64 })
        self.vocab.push(VocabEntry { token: "your",   id: 65 })
        self.vocab.push(VocabEntry { token: "name",   id: 66 })
        self.vocab.push(VocabEntry { token: "new",    id: 67 })
        self.vocab.push(VocabEntry { token: "very",   id: 68 })
        self.vocab.push(VocabEntry { token: "also",   id: 69 })

        -- KLC / AI 专用词汇
        self.vocab.push(VocabEntry { token: "Hello",      id: 80 })
        self.vocab.push(VocabEntry { token: "hello",      id: 81 })
        self.vocab.push(VocabEntry { token: "World",      id: 82 })
        self.vocab.push(VocabEntry { token: "world",      id: 83 })
        self.vocab.push(VocabEntry { token: "KLC",        id: 84 })
        self.vocab.push(VocabEntry { token: "AI",         id: 85 })
        self.vocab.push(VocabEntry { token: "language",   id: 86 })
        self.vocab.push(VocabEntry { token: "model",      id: 87 })
        self.vocab.push(VocabEntry { token: "code",       id: 88 })
        self.vocab.push(VocabEntry { token: "program",    id: 89 })
        self.vocab.push(VocabEntry { token: "transformer", id: 90 })
        self.vocab.push(VocabEntry { token: "tokenizer",  id: 91 })
        self.vocab.push(VocabEntry { token: "neural",     id: 92 })
        self.vocab.push(VocabEntry { token: "network",    id: 93 })
        self.vocab.push(VocabEntry { token: "learning",   id: 94 })
        self.vocab.push(VocabEntry { token: "deep",       id: 95 })
        self.vocab.push(VocabEntry { token: "data",       id: 96 })
        self.vocab.push(VocabEntry { token: "programming", id: 97 })
        self.vocab.push(VocabEntry { token: "test",       id: 98 })

        -- 单个 ASCII 字符 (ID 200-275)
        -- 小写 a-z (200-225)，注意 "a" 已在 id=32，此处跳过
        self.vocab.push(VocabEntry { token: "_a_dup", id: 200 })  -- placeholder: "a" at id=32
        self.vocab.push(VocabEntry { token: "b", id: 201 })
        self.vocab.push(VocabEntry { token: "c", id: 202 })
        self.vocab.push(VocabEntry { token: "d", id: 203 })
        self.vocab.push(VocabEntry { token: "e", id: 204 })
        self.vocab.push(VocabEntry { token: "f", id: 205 })
        self.vocab.push(VocabEntry { token: "g", id: 206 })
        self.vocab.push(VocabEntry { token: "h", id: 207 })
        self.vocab.push(VocabEntry { token: "i", id: 208 })
        self.vocab.push(VocabEntry { token: "j", id: 209 })
        self.vocab.push(VocabEntry { token: "k", id: 210 })
        self.vocab.push(VocabEntry { token: "l", id: 211 })
        self.vocab.push(VocabEntry { token: "m", id: 212 })
        self.vocab.push(VocabEntry { token: "n", id: 213 })
        self.vocab.push(VocabEntry { token: "o", id: 214 })
        self.vocab.push(VocabEntry { token: "p", id: 215 })
        self.vocab.push(VocabEntry { token: "q", id: 216 })
        self.vocab.push(VocabEntry { token: "r", id: 217 })
        self.vocab.push(VocabEntry { token: "s", id: 218 })
        self.vocab.push(VocabEntry { token: "t", id: 219 })
        self.vocab.push(VocabEntry { token: "u", id: 220 })
        self.vocab.push(VocabEntry { token: "v", id: 221 })
        self.vocab.push(VocabEntry { token: "w", id: 222 })
        self.vocab.push(VocabEntry { token: "x", id: 223 })
        self.vocab.push(VocabEntry { token: "y", id: 224 })
        self.vocab.push(VocabEntry { token: "z", id: 225 })

        -- 大写 A-Z (226-251)
        self.vocab.push(VocabEntry { token: "A", id: 226 })
        self.vocab.push(VocabEntry { token: "B", id: 227 })
        self.vocab.push(VocabEntry { token: "C", id: 228 })
        self.vocab.push(VocabEntry { token: "D", id: 229 })
        self.vocab.push(VocabEntry { token: "E", id: 230 })
        self.vocab.push(VocabEntry { token: "F", id: 231 })
        self.vocab.push(VocabEntry { token: "G", id: 232 })
        self.vocab.push(VocabEntry { token: "H", id: 233 })
        -- skip "I" (already at id=60)
        self.vocab.push(VocabEntry { token: "J", id: 235 })
        self.vocab.push(VocabEntry { token: "K", id: 236 })
        self.vocab.push(VocabEntry { token: "L", id: 237 })
        self.vocab.push(VocabEntry { token: "M", id: 238 })
        self.vocab.push(VocabEntry { token: "N", id: 239 })
        self.vocab.push(VocabEntry { token: "O", id: 240 })
        self.vocab.push(VocabEntry { token: "P", id: 241 })
        self.vocab.push(VocabEntry { token: "Q", id: 242 })
        self.vocab.push(VocabEntry { token: "R", id: 243 })
        self.vocab.push(VocabEntry { token: "S", id: 244 })
        self.vocab.push(VocabEntry { token: "T", id: 245 })
        self.vocab.push(VocabEntry { token: "U", id: 246 })
        self.vocab.push(VocabEntry { token: "V", id: 247 })
        self.vocab.push(VocabEntry { token: "W", id: 248 })
        self.vocab.push(VocabEntry { token: "X", id: 249 })
        self.vocab.push(VocabEntry { token: "Y", id: 250 })
        self.vocab.push(VocabEntry { token: "Z", id: 251 })

        -- 数字 0-9 (252-261)
        self.vocab.push(VocabEntry { token: "0", id: 252 })
        self.vocab.push(VocabEntry { token: "1", id: 253 })
        self.vocab.push(VocabEntry { token: "2", id: 254 })
        self.vocab.push(VocabEntry { token: "3", id: 255 })
        self.vocab.push(VocabEntry { token: "4", id: 256 })
        self.vocab.push(VocabEntry { token: "5", id: 257 })
        self.vocab.push(VocabEntry { token: "6", id: 258 })
        self.vocab.push(VocabEntry { token: "7", id: 259 })
        self.vocab.push(VocabEntry { token: "8", id: 260 })
        self.vocab.push(VocabEntry { token: "9", id: 261 })

        -- 常见子词单元（BPE 合并中间结果）
        -- 这些是合并规则的产出，也是词表的一部分
        self.vocab.push(VocabEntry { token: "th",   id: 300 })
        self.vocab.push(VocabEntry { token: "He",   id: 301 })
        self.vocab.push(VocabEntry { token: "er",   id: 302 })
        self.vocab.push(VocabEntry { token: "ll",   id: 303 })
        self.vocab.push(VocabEntry { token: "Hell", id: 304 })
        self.vocab.push(VocabEntry { token: "wor",  id: 305 })
        self.vocab.push(VocabEntry { token: "worl", id: 306 })
        self.vocab.push(VocabEntry { token: "ng",   id: 307 })
        self.vocab.push(VocabEntry { token: "ing",  id: 308 })
        self.vocab.push(VocabEntry { token: "KL",   id: 309 })
    }

    -- 初始化 BPE 合并规则
    --
    -- 合并规则按 rank 升序排列（rank 越小越先执行）。
    -- 每条规则定义了一对相邻 token 的合并方式。
    --
    -- 示例合并路径：
    --   "Hello" = [H,e,l,l,o]
    --     rank 4: (l,l)->ll  => [H,e,ll,o]
    --     rank 5: (H,e)->He  => [He,ll,o]
    --     rank 8: (He,ll)->Hell => [Hell,o]
    --     rank 9: (Hell,o)->Hello => [Hello]
    --
    --   "world" = [w,o,r,l,d]
    --     rank 6: (o,r)->or   => [w,or,l,d]
    --     rank 7: (w,or)->wor => [wor,l,d]
    --     rank 10: (wor,l)->worl => [worl,d]
    --     rank 11: (worl,d)->world => [world]
    --
    --   "the" = [t,h,e]
    --     rank 0: (t,h)->th   => [th,e]
    --     rank 1: (th,e)->the => [the]
    fn init_bpe_merges(self mut) {
        -- 基础字符合并
        self.merges.push(BPEMerge { left: "t",  right: "h",  rank: 0 })
        self.merges.push(BPEMerge { left: "th", right: "e",  rank: 1 })
        self.merges.push(BPEMerge { left: "i",  right: "n",  rank: 2 })
        self.merges.push(BPEMerge { left: "e",  right: "r",  rank: 3 })

        -- Hello 合并链
        self.merges.push(BPEMerge { left: "l",  right: "l",  rank: 4 })
        self.merges.push(BPEMerge { left: "H",  right: "e",  rank: 5 })

        -- world 合并链
        self.merges.push(BPEMerge { left: "o",  right: "r",  rank: 6 })
        self.merges.push(BPEMerge { left: "w",  right: "or", rank: 7 })

        -- Hello 后半段
        self.merges.push(BPEMerge { left: "He", right: "ll",  rank: 8 })
        self.merges.push(BPEMerge { left: "Hell", right: "o", rank: 9 })

        -- world 后半段
        self.merges.push(BPEMerge { left: "wor", right: "l",  rank: 10 })
        self.merges.push(BPEMerge { left: "worl", right: "d", rank: 11 })

        -- ing 后缀合并
        self.merges.push(BPEMerge { left: "n",  right: "g",  rank: 12 })
        self.merges.push(BPEMerge { left: "in", right: "g",  rank: 13 })

        -- AI / KLC 合并
        self.merges.push(BPEMerge { left: "A",  right: "I",  rank: 14 })
        self.merges.push(BPEMerge { left: "K",  right: "L",  rank: 15 })
        self.merges.push(BPEMerge { left: "KL", right: "C",  rank: 16 })
    }

    -- ═══════════ 编码方法 ═══════════

    -- 将文本编码为 Token ID 序列
    --
    -- 完整编码流程：
    --   1. 预处理（空格归一化）
    --   2. 预分词（按空格和标点拆分单词）
    --   3. 对每个单词应用 BPE 合并
    --   4. 查找词表获得 Token ID
    --   5. 可选：添加 BOS/EOS 特殊 token
    --
    -- 参数：
    --   text        - 输入文本
    --   add_special - 是否添加 BOS/EOS
    --
    -- 返回：Token ID 序列
    fn encode(self, text: str, add_special: bool) -> [i64] {
        -- 空字符串处理
        if text.len() == 0 {
            if add_special {
                return [self.bos_id, self.eos_id]
            }
            return []
        }

        -- Step 1: 预分词（拆分为单词数组）
        let words = pre_tokenize(text)

        -- Step 2: 对每个单词应用 BPE 并转换为 ID
        let mut ids = []
        let mut wi = 0
        while wi < words.len() {
            let word = words[wi]
            -- 先检查整词是否在词表中（快速路径）
            let wid = lookup_id(word, self.vocab)

            if wid != self.unk_id {
                -- 整词在词表中，直接使用
                ids.push(wid)
            } else {
                -- 整词不在词表中，应用 BPE 合并
                let bpe_tokens = apply_bpe(word, self.merges)
                let mut ti = 0
                while ti < bpe_tokens.len() {
                    let tid = lookup_id(bpe_tokens[ti], self.vocab)
                    ids.push(tid)
                    ti = ti + 1
                }
            }
            wi = wi + 1
        }

        -- Step 3: 添加特殊 token
        if add_special {
            let mut final_ids = [self.bos_id]
            let mut fi = 0
            while fi < ids.len() {
                final_ids.push(ids[fi])
                fi = fi + 1
            }
            final_ids.push(self.eos_id)
            return final_ids
        }

        return ids
    }

    -- 带完整信息的编码（返回 tokens 文本和 ID）
    fn encode_full(self, text: str, add_special: bool) -> EncodeOutput {
        let ids = self.encode(text, add_special)

        -- 构建 token 文本列表
        let mut tokens = []
        let mut i = 0
        while i < ids.len() {
            tokens.push(lookup_token(ids[i], self.vocab))
            i = i + 1
        }

        return EncodeOutput {
            ids: ids,
            tokens: tokens,
            count: ids.len()
        }
    }

    -- ═══════════ 解码方法 ═══════════

    -- 将 Token ID 序列解码为文本
    --
    -- 流程：
    --   1. 遍历每个 ID
    --   2. 可选：跳过特殊 token
    --   3. 查找对应的 token 文本
    --   4. 拼接所有 token 文本
    --
    -- 参数：
    --   ids          - Token ID 序列
    --   skip_special - 是否跳过 BOS/EOS/PAD 等特殊 token
    fn decode(self, ids: [i64], skip_special: bool) -> str {
        let mut parts = []
        let mut i = 0
        while i < ids.len() {
            let id = ids[i]

            -- 跳过特殊 token（仅当 skip_special 为 true 时过滤）
            -- BOS/EOS/PAD/MASK 不加入输出，其余正常解码
            if not skip_special or (id != self.bos_id and id != self.eos_id
                                    and id != self.pad_id and id != self.mask_id()) {
                let tok = lookup_token(id, self.vocab)
                parts.push(tok)
            }

            i = i + 1
        }

        return join_str(parts, "")
    }

    -- ═══════════ 工具方法 ═══════════

    -- 查找 token 对应的 ID（线性搜索词表）
    fn token_to_id(self, token: str) -> i64 {
        return lookup_id(token, self.vocab)
    }

    -- 查找 ID 对应的 token 文本（线性搜索词表）
    fn id_to_token(self, id: i64) -> str {
        return lookup_token(id, self.vocab)
    }

    -- 检查 ID 是否为特殊 token
    fn is_special_id(self, id: i64) -> bool {
        if id == self.bos_id or id == self.eos_id or id == self.pad_id {
            return true
        }
        if id == self.unk_id or id == self.mask_id() {
            return true
        }
        if id == 5 or id == 6 or id == 7 {
            return true
        }
        return false
    }

    -- 获取 MASK token ID
    fn mask_id(self) -> i64 = 4

    -- 截断序列到最大长度（适配模型输入限制）
    fn truncate(self, ids: [i64], max_len: i64) -> [i64] {
        if ids.len() <= max_len {
            return ids
        }

        let mut result = []
        let mut i = 0
        while i < max_len {
            result.push(ids[i])
            i = i + 1
        }
        return result
    }

    -- 填充序列到指定长度
    fn pad(self, ids: [i64], target_len: i64) -> [i64] {
        if ids.len() >= target_len {
            return ids
        }

        let mut result = []
        let mut i = 0
        while i < ids.len() {
            result.push(ids[i])
            i = i + 1
        }
        let mut j = ids.len()
        while j < target_len {
            result.push(self.pad_id)
            j = j + 1
        }
        return result
    }

    -- 获取分词器信息摘要
    fn get_info(self) -> str {
        return self.name ++
               " | vocab=" ++ self.vocab_size.to_str() ++
               " | merges=" ++ self.merges.len().to_str() ++
               " | max_seq=" ++ self.max_seq_len.to_str()
    }

    -- ═══════════ 多模型适配方法 ═══════════

    -- 获取模型配置档案的完整信息
    -- 输出与 transformer_core.klc 的 ModelConfig 对齐的参数摘要
    fn get_profile_info(self) -> str {
        return self.profile.name ++
               " | hidden=" ++ self.profile.hidden_size.to_str() ++
               " | layers=" ++ self.profile.num_layers.to_str() ++
               " | heads=" ++ self.profile.num_heads.to_str() ++
               " | head_dim=" ++ self.profile.head_dim.to_str() ++
               " | inter=" ++ self.profile.intermediate_size.to_str() ++
               " | vocab=" ++ self.profile.vocab_size.to_str() ++
               " | max_seq=" ++ self.profile.max_seq_len.to_str()
    }

    -- 获取 RoPE 配置信息（与 TransformerBlock 的 RopeEncoder 对齐）
    fn get_rope_info(self) -> str {
        return "RoPE theta=" ++ self.profile.rope_theta.to_str() ++
               " | max_pos=" ++ self.profile.max_seq_len.to_str() ++
               " | head_dim=" ++ self.profile.head_dim.to_str()
    }

    -- 验证 Token ID 序列是否在当前模型约束范围内
    --
    -- 检查项：
    --   1. 序列长度 <= max_seq_len
    --   2. 所有 Token ID < vocab_size
    --   3. 无 UNK token（可选警告）
    --
    -- 返回：验证通过为 "OK"，否则返回错误描述
    fn validate_for_model(self, ids: [i64]) -> str {
        -- 检查序列长度
        if ids.len() > self.profile.max_seq_len {
            return "FAIL: seq_len=" ++ ids.len().to_str() ++
                   " exceeds max_seq=" ++ self.profile.max_seq_len.to_str()
        }

        -- 检查每个 token ID 是否在词表范围内
        let mut i = 0
        while i < ids.len() {
            if ids[i] >= self.profile.vocab_size {
                return "FAIL: token_id=" ++ ids[i].to_str() ++
                       " at pos=" ++ i.to_str() ++
                       " exceeds vocab_size=" ++ self.profile.vocab_size.to_str()
            }
            if ids[i] < 0 {
                return "FAIL: negative token_id=" ++ ids[i].to_str() ++
                       " at pos=" ++ i.to_str()
            }
            i = i + 1
        }

        -- 检查 UNK token
        let mut unk_count = 0
        let mut j = 0
        while j < ids.len() {
            if ids[j] == self.unk_id {
                unk_count = unk_count + 1
            }
            j = j + 1
        }

        if unk_count > 0 {
            return "WARN: " ++ unk_count.to_str() ++ " UNK tokens found"
        }

        return "OK: seq_len=" ++ ids.len().to_str() ++
               " / max_seq=" ++ self.profile.max_seq_len.to_str() ++
               " | vocab_range=[0," ++ (self.profile.vocab_size - 1).to_str() ++ "]"
    }

    -- 创建注意力掩码
    --
    -- 有效 token 位置为 1，填充位置为 0。
    -- 用于 Transformer 的自注意力计算中屏蔽填充 token。
    --
    -- 参数：
    --   ids         - Token ID 序列（可包含 PAD）
    --   total_len   - 总长度（含填充，通常为 max_seq_len 的倍数）
    --
    -- 返回：AttentionMask
    fn create_attention_mask(self, ids: [i64], total_len: i64) -> AttentionMask {
        -- 计算有效长度（排除尾部 PAD）
        let mut valid = ids.len()
        let mut v = ids.len() - 1
        while v >= 0 {
            if ids[v] != self.pad_id {
                valid = v + 1
                v = -1  -- 终止循环
            } else {
                v = v - 1
            }
        }

        -- 构建掩码
        let mut mask = []
        let mut i = 0
        while i < valid {
            mask.push(1)
            i = i + 1
        }
        while i < total_len {
            mask.push(0)
            i = i + 1
        }

        return AttentionMask {
            mask: mask,
            valid_len: valid,
            total_len: total_len
        }
    }

    -- 准备完整的模型输入
    --
    -- 完整流程：
    --   1. 编码文本（含 BOS/EOS）
    --   2. 验证序列约束
    --   3. 截断到 max_seq_len（如需要）
    --   4. 填充到 target_len（如指定）
    --   5. 生成注意力掩码
    --   6. 封装为 ModelInput
    --
    -- 参数：
    --   text        - 输入文本
    --   target_len  - 目标总长度（0 表示不填充）
    --
    -- 返回：ModelInput
    fn prepare_model_input(self, text: str, target_len: i64) -> ModelInput {
        -- Step 1: 编码
        let ids = self.encode(text, true)

        -- Step 2: 截断（保留 EOS，截断中间内容）
        let truncated = self.truncate(ids, self.profile.max_seq_len)

        -- Step 3: 确定填充目标
        let final_len = if target_len > 0 and target_len > truncated.len() {
            target_len
        } else {
            truncated.len()
        }

        -- Step 4: 填充
        let padded = self.pad(truncated, final_len)

        -- Step 5: 生成注意力掩码
        let attn_mask = self.create_attention_mask(padded, final_len)

        -- Step 6: 构建 ModelInput
        let has_bos = padded.len() > 0 and padded[0] == self.bos_id
        let last_pos = padded.len() - 1
        let has_eos = padded.len() > 0 and padded[last_pos] == self.eos_id

        return ModelInput {
            token_ids: padded,
            attention_mask: attn_mask.mask,
            seq_len: attn_mask.valid_len,
            total_len: final_len,
            has_bos: has_bos,
            has_eos: has_eos
        }
    }

    -- 安全编码：编码 + 验证 + 自动截断
    --
    -- 与 prepare_model_input 的区别：
    --   - 不生成注意力掩码
    --   - 不填充
    --   - 返回编码结果和验证状态
    --
    -- 返回：(ids, status_string)
    fn safe_encode(self, text: str, add_special: bool) -> ([i64], str) {
        let ids = self.encode(text, add_special)

        -- 检查是否需要截断
        let mut truncated = ids
        if ids.len() > self.profile.max_seq_len {
            truncated = self.truncate(ids, self.profile.max_seq_len)
        }

        let status = self.validate_for_model(truncated)
        return (truncated, status)
    }

    -- 跨模型兼容性检查
    --
    -- 验证编码结果在多个模型规格下是否都能通过约束检查。
    -- 返回每个模型的验证结果描述。
    fn cross_model_check(self, ids: [i64]) -> [str] {
        let mut results = []

        -- KLC:3B 检查
        let check_3b = self.validate_for_model(ids)
        results.push("KLC:3B(max_seq=4096,vocab=64000): " ++ check_3b)

        -- KLC-POR:9B 检查（更大约束，通常通过）
        if ids.len() <= 8192 {
            results.push("KLC-POR:9B(max_seq=8192,vocab=128000): OK")
        } else {
            results.push("KLC-POR:9B(max_seq=8192): FAIL: seq exceeds limit")
        }

        -- KLC-MAX:27B 检查（最大约束）
        if ids.len() <= 16384 {
            results.push("KLC-MAX:27B(max_seq=16384,vocab=128000): OK")
        } else {
            results.push("KLC-MAX:27B(max_seq=16384): FAIL: seq exceeds limit")
        }

        return results
    }

    -- 格式化注意力掩码为可读字符串
    -- 用于调试输出
    fn format_mask_str(mask: [i64]) -> str {
        let mut s = "["
        let mut i = 0
        while i < mask.len() {
            if i > 0 { s = s ++ "," }
            s = s ++ mask[i].to_str()
            i = i + 1
        }
        s = s ++ "]"
        return s
    }

    -- 格式化 ModelInput 为可读字符串
    fn format_model_input(inp: ModelInput) -> str {
        return "ModelInput { token_ids=" ++ format_ids(inp.token_ids) ++
               ", mask=" ++ BPETokenizer::format_mask_str(inp.attention_mask) ++
               ", seq_len=" ++ inp.seq_len.to_str() ++
               ", total_len=" ++ inp.total_len.to_str() ++
               ", BOS=" ++ bool_to_str(inp.has_bos) ++
               ", EOS=" ++ bool_to_str(inp.has_eos) ++
               " }"
    }
}

-- ══════════════════════════════════════════════════════════════════
-- 第四部分：核心 BPE 算法
-- ══════════════════════════════════════════════════════════════════
--
-- BPE (Byte-Pair Encoding) 核心算法：
--
--   输入：一个单词（字符串）
--   输出：BPE 合并后的 token 序列
--
--   算法步骤：
--     1. 将单词拆分为单个字符序列
--     2. 扫描所有相邻 token 对，找到 rank 最低的可合并对
--     3. 合并该对的所有出现位置
--     4. 重复步骤 2-3，直到没有可合并的对
--
--   时间复杂度：O(L^2 * M)
--     L = 单词长度，M = 合并规则数
--     对演示词表完全够用
-- ══════════════════════════════════════════════════════════════════

-- 对单个单词应用 BPE 合并算法
--
-- 参数：
--   word   - 待分词的单词
--   merges - BPE 合并规则数组
--
-- 返回：合并后的 token 字符串数组
fn apply_bpe(word: str, merges: [BPEMerge]) -> [str] {
    -- Step 1: 拆分为字符序列
    let mut symbols = str_to_chars(word)

    -- 单字符无需合并
    if symbols.len() <= 1 {
        return symbols
    }

    -- Step 2: 迭代合并（直到无法继续）
    let mut merged = true
    while merged {
        merged = false

        -- 找到当前最优合并（rank 最小）
        let best = find_best_merge(symbols, merges)

        -- best.0 = rank, best.1 = left, best.2 = right
        if best.0 < 999999 {
            -- 执行合并（合并所有出现位置）
            symbols = execute_merge(symbols, best.1, best.2)
            merged = true
        }
    }

    return symbols
}

-- 在 token 序列中找到 rank 最低的可合并对
--
-- 遍历所有相邻对，查找 merges 中的最佳匹配。
-- 返回三元组：(rank, left, right)
-- 若无匹配返回 (999999, "", "")
fn find_best_merge(symbols: [str], merges: [BPEMerge]) -> (i64, str, str) {
    let mut best_rank = 999999
    let mut best_left = ""
    let mut best_right = ""

    let mut i = 0
    while i < symbols.len() - 1 {
        let left = symbols[i]
        let right = symbols[i + 1]

        -- 在 merges 中查找这对的 rank
        let mut mi = 0
        while mi < merges.len() {
            if merges[mi].left == left and merges[mi].right == right {
                if merges[mi].rank < best_rank {
                    best_rank = merges[mi].rank
                    best_left = left
                    best_right = right
                }
            }
            mi = mi + 1
        }

        i = i + 1
    }

    return (best_rank, best_left, best_right)
}

-- 执行合并：将所有相邻的 (left, right) 对替换为 left++right
--
-- 重要：合并所有出现位置（不是仅第一个）
-- 例如：["a", "a", "a", "a"] + merge(a,a) → ["aa", "aa"]
fn execute_merge(symbols: [str], left: str, right: str) -> [str] {
    let mut result = []
    let mut i = 0

    while i < symbols.len() {
        -- 检查当前位置是否可合并（需要 i+1 在范围内）
        if i + 1 < symbols.len() {
            if symbols[i] == left and symbols[i + 1] == right {
                -- 执行合并，跳过两个符号
                result.push(left ++ right)
                i = i + 2
            } else {
                result.push(symbols[i])
                i = i + 1
            }
        } else {
            -- 最后一个符号，无法合并
            result.push(symbols[i])
            i = i + 1
        }
    }

    return result
}

-- ══════════════════════════════════════════════════════════════════
-- 第五部分：文本预处理
-- ══════════════════════════════════════════════════════════════════
--
-- 预分词（Pre-tokenization）：
--   将原始文本拆分为单词级别的片段。
--
-- 拆分规则：
--   1. 空格作为单词分隔符（空格本身不保留为 token）
--   2. 标点符号单独成 token
--   3. 换行符单独成 token
--   4. 其他字符组成连续单词
--
-- 示例：
--   "Hello, world!" → ["Hello", ",", "world", "!"]
--   "KLC is great"  → ["KLC", "is", "great"]
-- ══════════════════════════════════════════════════════════════════

-- 预分词：将文本拆分为单词/标点 token 数组
fn pre_tokenize(text: str) -> [str] {
    let chars_arr = str_to_chars(text)
    let mut words = []
    let mut current = ""
    let mut i = 0

    while i < chars_arr.len() {
        let ch = chars_arr[i]

        if ch == " " {
            -- 空格：结束当前单词
            if current.len() > 0 {
                words.push(current)
                current = ""
            }
        } else if ch == "\n" or ch == "\t" {
            -- 换行/制表：结束当前单词，换行单独成 token
            if current.len() > 0 {
                words.push(current)
                current = ""
            }
            words.push(ch)
        } else if is_punct(ch) {
            -- 标点：结束当前单词，标点单独成 token
            if current.len() > 0 {
                words.push(current)
                current = ""
            }
            words.push(ch)
        } else {
            -- 普通字符：追加到当前单词
            current = current ++ ch
        }

        i = i + 1
    }

    -- 处理末尾残余
    if current.len() > 0 {
        words.push(current)
    }

    return words
}

-- 判断字符是否为标点符号
fn is_punct(ch: str) -> bool {
    if ch == "," or ch == "." or ch == "!" or ch == "?" { return true }
    if ch == ";" or ch == ":" or ch == "\"" or ch == "'" { return true }
    if ch == "(" or ch == ")" or ch == "-" or ch == "_" { return true }
    if ch == "[" or ch == "]" or ch == "{" or ch == "}" { return true }
    if ch == "<" or ch == ">" or ch == "/" or ch == "\\" { return true }
    if ch == "@" or ch == "#" or ch == "$" or ch == "%" { return true }
    if ch == "^" or ch == "&" or ch == "*" or ch == "~" { return true }
    if ch == "`" or ch == "|" or ch == "=" or ch == "+" { return true }
    return false
}

-- 将字符串拆分为单字符字符串数组
--
-- 使用 chars() 获取字符数组，while 循环逐个提取
fn str_to_chars(s: str) -> [str] {
    let mut result = []
    let char_list = chars(s)
    let mut i = 0
    while i < char_list.len() {
        result.push("" ++ char_list[i])
        i = i + 1
    }
    return result
}

-- ══════════════════════════════════════════════════════════════════
-- 第六部分：词表查找工具
-- ══════════════════════════════════════════════════════════════════
--
-- 由于 KLC 无原生 dict/map，使用线性搜索。
-- 对演示词表（~300 条）完全够用。
-- 查找复杂度 O(n)，生产环境应替换为哈希表。
-- ══════════════════════════════════════════════════════════════════

-- 在词表中查找 token 对应的 ID
-- 未找到返回 UNK ID (1)
fn lookup_id(token: str, vocab: [VocabEntry]) -> i64 {
    let mut i = 0
    while i < vocab.len() {
        if vocab[i].token == token {
            return vocab[i].id
        }
        i = i + 1
    }
    return 1  -- UNK
}

-- 在词表中查找 ID 对应的 token 文本
-- 未找到返回 "<UNK>"
fn lookup_token(id: i64, vocab: [VocabEntry]) -> str {
    let mut i = 0
    while i < vocab.len() {
        if vocab[i].id == id {
            return vocab[i].token
        }
        i = i + 1
    }
    return "<UNK>"
}

-- ══════════════════════════════════════════════════════════════════
-- 第七部分：字符串工具函数
-- ══════════════════════════════════════════════════════════════════

-- 连接字符串数组
fn join_str(arr: [str], sep: str) -> str {
    if arr.len() == 0 { return "" }
    if arr.len() == 1 { return arr[0] }

    let mut s = arr[0]
    let mut i = 1
    while i < arr.len() {
        s = s ++ sep ++ arr[i]
        i = i + 1
    }
    return s
}

-- 将 i64 数组格式化为可读字符串
-- 输入: [2, 80, 8, 83, 3]
-- 输出: "[2, 80, 8, 83, 3]"
fn format_ids(arr: [i64]) -> str {
    if arr.len() == 0 { return "[]" }

    let mut s = "[" ++ arr[0].to_str()
    let mut i = 1
    while i < arr.len() {
        s = s ++ ", " ++ arr[i].to_str()
        i = i + 1
    }
    s = s ++ "]"
    return s
}

-- 将字符串数组格式化为可读字符串
fn format_tokens(arr: [str]) -> str {
    if arr.len() == 0 { return "[]" }

    let mut s = "[" ++ arr[0]
    let mut i = 1
    while i < arr.len() {
        s = s ++ ", " ++ arr[i]
        i = i + 1
    }
    s = s ++ "]"
    return s
}

-- ══════════════════════════════════════════════════════════════════
-- 第八部分：测试套件
-- ══════════════════════════════════════════════════════════════════

