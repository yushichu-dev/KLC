--- 设置演示模式的轻量级引擎
fn setup_demo_engine(integration: KLCIDEIntegration mut) {
    -- 在实际应用中，这里会加载真实模型
    -- 演示模式下使用简化版本
}

--- 提取光标前的代码上下文
fn extract_context_before_cursor(code: str, cursor_pos: i64) -> str {
    if cursor_pos <= 0 { return "" }
    if cursor_pos > code.len() { return code }
    return code.substring(0, cursor_pos)
}

--- 对代码上下文计算哈希（用于缓存键）
fn hash_code_context(context: str) -> str {
    -- 简化的哈希实现
    let hash = 0
    for ch in chars(context) {
        hash = (hash * 31 + ch as i64) % 2147483647
    }
    return "ctx_" ++ hash.to_str()
}

--- 检测补全项的类型
fn detect_completion_kind(text: str) -> str {
    -- 关键字检测
    let keywords = [
        "fn", "let", "mut", "if", "else", "for", "while", "loop",
        "return", "break", "continue", "struct", "type", "enum",
        "match", "impl", "pub", "priv", "use", "mod", "import",
        "true", "false", "null", "and", "or", "not", "in"
    ]

    for kw in keywords {
        if text == kw or text.starts_with(kw ++ " ") or text.starts_with(kw ++ "(") {
            return "keyword"
        }
    }

    -- 函数检测
    if text.contains("(") and text.ends_with("(") {
        return "function"
    }

    -- 变量检测
    if text.starts_with("let ") or text.starts_with("const ") {
        return "variable"
    }

    -- 类型检测
    if text.starts_with(": ") and (text.contains("[") or text.contains("{")) {
        return "type"
    }

    return "snippet"
}

--- 计算补全置信度
fn calculate_confidence(completion: str, context: str) -> f64 {
    let confidence = 0.5  -- 基础置信度

    -- 上下文长度越长，置信度越高（更多信息可用）
    if context.len() > 50 {
        confidence = confidence + 0.1
    }
    if context.len() > 200 {
        confidence = confidence + 0.1
    }

    -- 匹配常见模式增加置信度
    if completion.starts_with("fn ") { confidence = confidence + 0.15 }
    if completion.contains(".klc") { confidence = confidence + 0.05 }

    -- 合法性检查
    if is_valid_klc_syntax(completion) { confidence = confidence + 0.1 }

    return math.min(confidence, 1.0)
}

--- 简单的 KLC 语法合法性检查
fn is_valid_klc_syntax(text: str) -> bool {
    -- 非常简化的检查
    if text.contains("(") and not text.contains(")") {
        return false
    }
    if text.count("{") != text.count("}") {
        return false  -- 可能不完整
    }
    return true
}

--- 计算子串出现次数
fn count_occurrences(s: str, substr: str) -> i64 {
    let count = 0
    let mut pos = 0

    while pos < s.len() {
        let found = s.find(substr, pos)
        if found < 0 { break }
        count = count + 1
        pos = found + substr.len()
    }

    return count
}

--- 从字符串中提取行号
fn extract_line_number(line: str) -> i64 {
    -- 简单的正则式匹配
    let patterns = [
        "Line ", "line ", "L", ":"
    ]

    for pat in patterns {
        let idx = line.find(pat)
        if idx >= 0 {
            let after_pat = line.substring(idx + pat.len())
            let num_str = ""
            for ch in chars(after_pat) {
                if ch >= '0' and ch <= '9' {
                    num_str = num_str ++ to_str(ch)
                } else {
                    break
                }
            }
            if num_str.len() > 0 {
                return num_str.to_i64()
            }
        }
    }

    return 0
}

-- |===========================================================================|
-- |                      DLL 导出接口（Windows）                                 |
-- |===========================================================================|
--
-- 以下是导出给外部调用的 C 兼容接口。
-- 这些函数可以被 KLC IDE 作为 DLL 或静态库链接使用。
--
-- C 头文件声明示例：
-- /*
-- // klcaide.h - KLC AI IDE Integration Header
--
-- #ifdef __cplusplus
-- extern "C" {
-- #endif
--
-- // 初始化
-- __declspec(dllexport) int KLCA_Init(const char* model_dir);
--
-- // AI 对话
-- __declspec(dllexport) int KLCA_Chat(const char* session_id,
--                                      const char* message,
--                                      char* output_buffer,
--                                      int buffer_size);
--
-- // 代码补全
-- __declspec(dllexport) int KLCA_Complete(const char* code,
--                                          int cursor_pos,
--                                          char* output_buffer,
--                                          int buffer_size);
--
-- // 代码检查
-- __declspec(dllexport) int KLCA_Lint(const char* code,
--                                     char* output_buffer,
--                                     int buffer_size);
--
-- // 清理
-- __declspec(dllexport) void KLCA_Shutdown(void);
--
-- #ifdef __cplusplus
-- }
-- #endif
-- */

--- 全局 IDE 实例指针（DLL 场景下使用）
let g_ide_instance: KLCIDEIntegration? = null

--- 初始化 DLL 接口
---
/// 对应 C 函数: int KLCA_Init(const char* model_dir)
pub fn dll_init(model_dir: str) -> i64 {
    g_ide_instance = KLCIDEIntegration::new(model_dir)
    let response = g_ide_instance.initialize()

    if response.success {
        return SUCCESS
    }
    return response.code
}

--- AI 对话（DLL 接口）
---
/// 对应 C 函数: int KLCA_Chat(...)
pub fn dll_chat(session_id: str, message: str, buffer_size: i64 = 4096) -> (i64, str) {
    if g_ide_instance == null {
        return (ERR_NOT_INITIALIZED, "")
    }

    let response = g_ide_instance.chat(message, session_id)

    if response.success {
        let reply = response.data["reply"] as str
        if reply.len() <= buffer_size {
            return (SUCCESS, reply)
        }
        return (SUCCESS, reply.substring(0, buffer_size))
    }

    return (response.code, response.error_message ?? "")
}

--- 代码补全（DLL 接口）
pub fn dll_complete(code: str, cursor_pos: i64, buffer_size: i64 = 4096) -> (i64, [CompletionItem]) {
    if g_ide_instance == null {
        return (ERR_NOT_INITIALIZED, [])
    }

    let response = g_ide_instance.code_complete(code, cursor_pos)

    if response.success {
        let result = response.data as CompletionItem[]
        return (SUCCESS, result)
    }

    return (response.code, [])
}

--- 代码检查（DLL 接口）
pub fn dll_lint(code: str) -> (i64, LintResult?) {
    if g_ide_instance == null {
        return (ERR_NOT_INITIALIZED, null)
    }

    let response = g_ide_instance.lint_code(code)

    if response.success {
        return (SUCCESS, response.data as LintResult?)
    }

    return (response.code, null)
}

--- 关闭 DLL（清理资源）
pub fn dll_shutdown() -> i64 {
    if g_ide_instance != null {
        g_ide_instance.shutdown()
        g_ide_instance = null
        return SUCCESS
    }
    return ERR_NOT_INITIALIZED
}

