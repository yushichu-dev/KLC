}

--- 时间相关
fn time_now() -> i64 {
    return 0  -- 实际应使用系统时钟
}

--- 检查文件是否存在
fn file_exists(path: str) -> bool {
    -- 简化实现：假设文件不存在（演示模式）
    return false
}

--- 生成 UUID（简化版）
fn generate_uuid() -> str {
    return "session_" ++ time_now().to_str() ++ "_" ++
           random_int(1000, 9999).to_str()
}

--- 生成随机整数
fn random_int(min: i64, max: i64) -> i64 {
    return min + (time_now() % (max - min + 1))
}

--- 格式化功能标志
fn format_features(flags: i64) -> str {
    let features = []
    if flags & FEATURE_CHAT != 0 { features.push("Chat") }
    if flags & FEATURE_CODE_COMPLETE != 0 { features.push("Complete") }
    if flags & FEATURE_LINT != 0 { features.push("Lint") }
    if flags & FEATURE_EXPLAIN != 0 { features.push("Explain") }
    if flags & FEATURE_FIX != 0 { features.push("AutoFix") }
    if features.is_empty() { features.push("(none)") }
    return join(features, ", ")
}

--- 连接字符串数组
fn join(arr: [str], sep: str) -> str {
    if arr.is_empty() { return "" }
    let result = arr[0]
    for i in 1..arr.len() {
        result = result ++ sep ++ arr[i]
    }
    return result
}

--- 创建成功响应
fn success_response(data: any?) -> APIResponse {
    return APIResponse {
        success: true,
        code: SUCCESS,
        data: data,
        error_message: null,
        processing_time_ms: 0
    }
}

--- 创建错误响应
fn error_response(code: i64, message: str) -> APIResponse {
    return APIResponse {
        success: false,
        code: code,
        data: null,
        error_message: message,
        processing_time_ms: 0
