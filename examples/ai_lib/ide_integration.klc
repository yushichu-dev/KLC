--- 完整演示：IDE 集成的所有功能
fn demo_ide_integration() {
    io.println("╔══════════════════════════════════════════════╗")
    io.println("║     KLC IDE 集成接口 — 完整演示                ║")
    io.println("╚══════════════════════════════════════════════╝")
    io.println()

    -- 步骤 1: 初始化
    io.println("步骤 1: 初始化 IDE 集成")
    io.println("-" .repeat(50))

    let ide = KLCIDEIntegration::new("./models")
    let init_result = ide.initialize(FEATURE_CHAT | FEATURE_CODE_COMPLETE |
                                   FEATURE_LINT | FEATURE_EXPLAIN)

    if not init_result.success {
        io.println("✗ 初始化失败: " ++ init_result.error_message ?? "Unknown error")
        exit(1)
    }

    io.println("✓ 初始化成功")
    io.println("  版本: " ++ (init_result.data["version"] as str))
    io.println("  功能: " ++ format_features(init_result.data["features"] as i64))
    io.println()

    -- 步骤 2: AI 对话
    io.println("步骤 2: AI 对话功能")
    io.println("-" .repeat(50))

    let questions = [
        "你好！请介绍一下你自己。",
        "KLC编程语言有哪些主要特点？",
        "如何编写一个Hello World程序？",
        "请帮我写一个快速排序算法。",
        "什么是Transformer架构？"
    ]

    for q in questions {
        io.print("\n[User]: " ++ q ++ "\n")

        let chat_response = ide.chat(q)
        if chat_response.success {
            let reply = chat_response.data["reply"] as str
            io.println("[Assistant]: " ++ reply)
            io.println("  (TPS: " ++
                       ("%.2f" % (chat_response.data["tokens_per_second"] as f64)) ++
                       ")")
        }
    }
    io.println()

    -- 步骤 3: 代码补全
    io.println("步骤 3: 代码补全功能")
    io.println("-" .repeat(50))

    let code_samples = [
        ("fn main() {\n    io.pr", 22),
        ("let result = array.map(|item| item.valu", 45),
        ("struct Person {\n    name: Str", 29),
        ("for i in 0..100 {\n    if i % 2 == 0 {\n        pri", 42),
        ("use tensor::{Tensor, Shape}\nlet t = Tensor::zeros(", 47)
    ]

    for (code, cursor) in code_samples {
        io.println("\n代码:")
        io.println("  " ++ code.replace("\n", "\n  "))
        io.println("  " ++ " ".repeat(cursor - code.split("\n").last().len()) ++ "^")

        let comp_response = ide.code_complete(code, cursor)
        if comp_response.success {
            let result = comp_response.data as CompletionResult
            io.println("补全建议 (" ++ result.items.len().to_str() ++ " 个):")

            for i in 0..math.min(3, result.items.len()) {
                let item = result.items[i]
                io.println("  " ++ (i+1).to_str() ++ ". [" ++ item.kind ++ "] " ++
                           item.display_text ++ " (" ++
                           ("%.0f" % (item.confidence * 100)) ++ "%)")
            }
        }
    }
    io.println()

    -- 步骤 4: 语法检查
    io.println("步骤 4: 代码检查 (Lint)")
    io.println("-" .repeat(50))

    let code_to_check = """
fn calculate_average(numbers: [f64]) -> f64 {
    let sum = 0.0
    for n in numbers {
        sum = sum + n  -- Potential overflow for large arrays
    }
    return sum / numbers.length  -- Division by zero if empty!
}

fn process_data(data: [i64]) -> [i64] {
    let result = []
    for i in 0..data.length {
        if data[i] > 0:
            result.push(data[i] * 2)
    }
    return result
}
"""
    io.println("检查代码:")
    io.println(code_to_check)

    let lint_response = ide.lint_code(code_to_check, "warning")
    if lint_response.success {
        let lint_result = lint_response.data as LintResult
        io.println("\n检查结果:")
        io.println("  错误: " ++ lint_result.error_count.to_str())
        io.println("  警告: " ++ lint_result.warning_count.to_str())

        if lint_result.issues.len() > 0 {
            io.println("\n  问题详情:")
            for issue in lint_result.issues {
                io.println("  [" ++ issue.severity.to_upper() ++
                           "] Line " ++ issue.line.to_str() ++ ": " ++
                           issue.message)
                if issue.suggestion != null {
                    io.println("    → " ++ issue.suggestion)
                }
            }
        }
    }
    io.println()

    -- 步骤 5: 代码解释
    io.println("步骤 5: 代码解释功能")
    io.println("-" .repeat(50))

    let complex_code = """
// 快速排序实现
fn quicksort<T>(arr: [T] mut, low: i64, high: i64) {
    if low < high {
        let pivot_idx = partition(arr, low, high)
        quicksort(arr, low, pivot_idx - 1)
        quicksort(arr, pivot_idx + 1, high)
    }
}

fn partition<T>(arr: [T] mut, low: i64, high: i64) -> i64 {
    let pivot = arr[high]
    let mut i = low - 1

    for j in low..high {
        if arr[j] <= pivot {
            i = i + 1
            swap(&arr[i], &arr[j])
        }
    }
    swap(&arr[i + 1], &arr[high])
    return i + 1
}
"""
    io.println("待解释代码:")
    io.println(complex_code)

    let explain_response = ide.explain_code(complex_code, "standard")
    if explain_response.success {
        let explain_result = explain_response.data as ExplainResult
        io.println("\n【摘要】")
        io.println("  " ++ explain_result.summary)
        io.println("\n【详细解释】")
        io.println("  " ++ explain_result.detailed.substring(0, 500) ++ "...")
        io.println("\n【复杂度】: " ++ explain_result.complexity)
    }
    io.println()

    -- 步骤 6: 状态查询
    io.println("步骤 6: 系统状态")
    io.println("-" .repeat(50))
    let status = ide.get_status()
    io.println(status)
    io.println()

    -- 步骤 7: 清理
    io.println("步骤 7: 清理资源")
    ide.shutdown()
    io.println("✓ 资源已释放")

    io.println()
    io.println("═══════════════════════════════════════════")
    io.println("  ✓ IDE 集成演示完成")
    io.println("═══════════════════════════════════════════")
}

fn main() {
    demo_ide_integration()
}
