fn test_transformer_components() {
    io.Println("━━━ 测试 5: Transformer 组件 ━━━")

    -- 使用 3B 配置
    let config = ModelConfig::klc_3b()
    io.Println("模型配置: " ++ config.model_name)
    io.Println("  隐藏维度:  " ++ config.hidden_size.to_str())
    io.Println("  层数:       " ++ config.num_layers.to_str())
    io.Println("  注意力头数: " ++ config.num_heads.to_str())
    io.Println("  头维度:     " ++ config.head_dim.to_str())
    io.Println("  中间层大小: " ++ config.intermediate_size.to_str())
    io.Println("  最大序列:   " ++ config.max_position_embeddings.to_str())
    io.Println("  参数量: ~" ++ format_number(config.parameter_count))
    io.Println("  GQA: " ++ (if config.uses_gqa() { "是" } else { "否" }))
    io.Println()

    -- ═══ RoPE 编码器测试 ═══
    io.Println("旋转位置编码 (RoPE):")
    let rope = RopeEmbedding::new(head_dim=config.head_dim, max_seq_len=128)

    let q = Tensor::random(Shape { dims: [config.head_dim] }, seed=123)
    io.Println("  Q (pos=0): [" ++ format_vector(q.data, 5) ++ "]")

    let q_rotated = rope.apply(q, position=0)
    io.Println("  Q_rot (pos=0): [" ++ format_vector(q_rotated.data, 5) ++ "]")

    let q_rotated_10 = rope.apply(q, position=10)
    io.Println("  Q_rot (pos=10): [" ++ format_vector(q_rotated_10.data, 5) ++ "]")

    io.Println("  → 不同位置的编码不同，位置信息已注入")

    -- ═══ 单个 Transformer Block 测试 ═══
    io.Println("\nTransformer Block 测试:")

    let block = TransformerBlock::new(config)

    -- 模拟输入（batch=1, seq_len=4, hidden=2560 的简化版）
    let test_input = Tensor::random(
        Shape { dims: [1, 4, config.hidden_size] },
        seed=42
    )

    io.Println("  输入形状: [1, 4, " ++ config.hidden_size.to_str() ++ "]")

    -- 注意：实际前向传播需要加载权重
    -- 这里仅验证结构正确性
    let normed_input = block.attn_norm.forward(test_input.reshape(Shape {dims:[4, config.hidden_size]}))
    io.Println("  Attention Norm 输出形状: " ++ normed_input.shape.dims.to_str())

    let ffn_normed = block.ffn_norm.forward(test_input.reshape(Shape {dims:[4, config.hidden_size]}))
    io.Println("  FFN Norm 输出形状: " ++ ffn_normed.shape.dims.to_str())

    io.Println("  ✓ Block 结构正确，各子组件就绪")

    -- ═══ 多规格配置对比 ═══
    io.Println("\n多规格模型配置对比:")
    print_model_specs(ModelConfig::klc_3b(), "KLC:3B")
    print_model_specs(ModelConfig::klc_9b(), "KLC:9B")
    print_model_specs(ModelConfig::klc_27b(), "KLC:27B")

    io.Println("✓ Transformer 组件测试通过")
}

fn print_model_specs(cfg: ModelConfig, name: str) {
    io.Println("  " ++ name ++ ":")
    io.Println("    Hidden: " ++ cfg.hidden_size.to_str() ++
               " | Layers: " ++ cfg.num_layers.to_str() ++
               " | Heads: " ++ cfg.num_heads.to_str() ++
               "/" ++ cfg.num_kv_heads.to_str() +
               (if cfg.uses_gqa() { " (GQA)" } else { "" }) ++
               " | Params: ~" ++ cfg.parameter_count.to_str())
}

-- |===========================================================================|
-- |              测试 6: 端到端生成流程                                       |
-- |===========================================================================|

fn demo_end_to_end_generation() {
    io.Println("━━━ 测试 6: 端到端生成流程 ━━━")

    -- ═══ 初始化模型 ═══
    io.Println("步骤 1: 初始化 KLC:3B 模型...")

    let pool = MemoryPool::new(initial_size=512 * 1024 * 1024)  -- 512MB 用于演示
    let model = KLCTransformerModel::new(ModelConfig::klc_3b(), pool)

    io.Println("  ✓ 模型结构已创建")
    io.Println("  ✓ 内存池已预分配: 512 MB")
    io.Println()

    -- ═══ 准备输入 ═══
    io.Println("步骤 2: 准备输入序列...")

    -- 模拟 token IDs（实际应来自 tokenizer）
    let prompt_tokens = [15496,   -- "Hello"
                         4435,    -- " my"
                         393,     -- " name"
                         373,     -- " is"
                         1296,    -- " KLC"
                         13]      -- "."

    io.Println("  Prompt tokens: " ++ prompt_tokens.to_str())
    io.Println("  Token 数: " ++ prompt_tokens.len().to_str())
    io.Println()

    -- ═══ 执行推理（简化演示）═══
    io.Println("步骤 3: 执行自回归生成...")
    io.Println("  （此处为流程演示，实际需加载训练权重）")

    -- 模拟生成循环
    let max_new_tokens = 16
    let generated_tokens = prompt_tokens.clone()

    for step in 0..max_new_tokens {
        -- 在实际实现中，这里会执行完整的 Transformer forward pass
        -- 并从 logits 中采样下一个 token

        -- 演示：模拟采样过程
        let mut next_token = 0

        -- 使用简单的伪随机方式模拟（仅用于演示）
        let pseudo_random = (step * 17 + 42) % 32000
        next_token = pseudo_random

        generated_tokens.push(next_token)

        -- 检查终止条件
        if next_token == EOS_TOKEN_ID or
           generated_tokens.len() > 128 {
            break
        }

        io.Println("  Step " ++ (step+1).to_str() ++ "/" ++
                   max_new_tokens.to_str() ++ ": token=" ++
                   next_token.to_str())
    }

    io.Println()
    io.Println("步骤 4: 生成结果:")
    io.Println("  完整序列: " ++ generated_tokens.to_str())
    io.Println("  生成长度: " ++ (generated_tokens.len() - prompt_tokens.len()).to_str() ++
               " tokens")
    io.Println()

    -- ═══ 资源清理 ═══
    io.Println("步骤 5: 清理资源...")
    pool.reset_all()
    io.Println("  ✓ 内存池已重置")
    io.Println()

    io.Println("✓ 端到端生成流程演示完成")
    io.Println("  提示: 加载真实权重文件后即可进行实际推理")
}

-- |===========================================================================|
-- |                    性能基准测试                                             |
-- |===========================================================================|

fn benchmark_performance() {
    io.Println("━━━ 性能基准测试 ━━━")

    let sizes = [256, 512, 1024, 2048]

    io.Println("\n矩阵乘法性能 (2D @ 2D):")
    for n in sizes {
        let a = Tensor::random(Shape { dims: [n, n] }, seed=1)
        let b = Tensor::random(Shape { dims: [n, n] }, seed=2)

        let start_time = time.now()
        let result = a.matmul(b)
        let elapsed = time.since(start_time)  -- 假设的时间测量函数

        let flops = 2.0 * n as f64 * n as f64 * n as f64
        let gflops = flops / (elapsed * 1e9)

        io.Println("  " ++ n.to_str() ++ "×" ++ n.to_str() ++ ": " ++
                   ("%.2f" % (elapsed * 1000)) ++ " ms | ~" ++
                   ("%.2f" % gflops) ++ " GFLOPS")
    }

    io.Println("\n激活函数吞吐量 (向量长度=4096):")
    let large_vec = Tensor::random(Shape { dims: [4096] }, seed=99)

    let activations = [
        ("ReLU  ", relu),
        ("GELU  ", gelu),
        ("SiLU  ", silu),
        ("Mish  ", mish),
        ("Tanh  ", tanh_act)
    ]

    for (name, fn_ptr) in activations {
        let iterations = 10000

        let start = time.now()
        for _ in 0..iterations {
            let _ = fn_ptr(large_vec)
        }
        let elapsed = time.since(start)

        let throughput = (iterations * 4096.0) / elapsed

        io.Println("  " ++ name ++ ": " ++
                   ("%.3f" % (elapsed * 1000 / iterations)) ++ " ms/call | " ++
                   ("%.2e" % throughput) ++ " elem/s")
    }

    io.Println("\n注意: 以上数据基于 KLC VM 解释器执行")
    io.Println("  原生编译 (--native) 可获得 10-100x 加速")
}

fn tanh_act(x: Tensor) -> Tensor {
    let n = x.size()
    let mut result = []
    for i in 0..n {
        result.push(math.tanh(x.data[i]))
    }
    return Tensor::from_shape(x.get_shape(), result)
}

-- |===========================================================================|
-- |                      辅助工具函数                                         |
-- |===========================================================================|

--- 格式化向量显示（截断长向量）
fn format_vector(data: [f64], max_items: i64) -> str {
    let mut s = ""
    let limit = math.min(data.len(), max_items)

    for i in 0..limit {
        if i > 0 { s = s ++ ", " }
        s = s ++ ("%.3f" % data[i])
    }

    if data.len() > max_items {
        s = s ++ ", ... (+" ++ (data.len() - max_items).to_str() ++ ")"
    }

    return s
}

