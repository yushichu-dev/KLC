-- ============================================================================
-- KLC:AI 归一化函数库
-- 版本: v1.0.0
-- 实现 LayerNorm, RMSNorm 等归一化层，用于 Transformer 模型训练稳定
-- ============================================================================

mod normalization

use tensor

-- |===========================================================================|
-- |                        Layer Normalization                                 |
-- |===========================================================================|

--- LayerNorm 层（可学习参数版本）
---
--- LayerNorm 对每个样本的所有特征进行归一化，
--- 不受 batch size 影响，是 Transformer 的核心组件。
---
--- 公式：
---   y = γ * (x - μ) / √(σ² + ε) + β
--- 其中：
---   μ = mean(x)        （均值）
---   σ² = var(x)        （方差）
---   γ, β = 可学习的缩放/偏移参数
---   ε = 数值稳定性常数
type LayerNorm {
    normalized_shape: i64  -- 归一化的维度大小
    eps: f64              -- 数值稳定性常数（默认 1e-5）
    gamma: Tensor         -- 缩放参数 γ
    beta: Tensor          -- 偏移参数 β
}

impl LayerNorm {
    --- 创建 LayerNorm 层
    pub fn new(normalized_shape: i64, eps: f64 = 1e-5) -> LayerNorm {
        let shape = Shape { dims: [normalized_shape] }

        return LayerNorm {
            normalized_shape: normalized_shape,
            eps: eps,
            gamma: Tensor::ones(shape),      -- γ 初始化为 1
            beta: Tensor::zeros(shape)       -- β 初始化为 0
        }
    }

    --- 前向传播
    --- 输入：x 形状为 [batch_size, normalized_shape] 或 [normalized_shape]
    --- 输出：归一化后的张量，形状与输入相同
    pub fn forward(self, x: Tensor) -> Tensor {
        -- 支持向量输入（2D 自动处理）
        if x.is_vector() {
            return self.forward_1d(x)
        }
        if x.is_matrix() {
            return self.forward_2d(x)
        }

        io.println("Error: LayerNorm 支持 1D 或 2D 张量")
        exit(1)
    }

    --- 向量前向传播
    fn forward_1d(self, x: Tensor) -> Tensor {
        if x.size() != self.normalized_shape {
            io.println("Error: 输入维度与 normalized_shape 不匹配")
            exit(1)
        }

        -- 计算均值
        let mut mean = 0.0
        for i in 0..self.normalized_shape {
            mean = mean + x.data[i]
        }
        mean = mean / self.normalized_shape

        -- 计算方差（使用两遍算法保证数值精度）
        let mut variance = 0.0
        for i in 0..self.normalized_shape {
            let diff = x.data[i] - mean
            variance = variance + diff * diff
        }
        variance = variance / self.normalized_shape

        -- 归一化
        let std_inv = 1.0 / math.sqrt(variance + self.eps)

        let mut result = []
        for i in 0..self.normalized_shape {
            let normalized = (x.data[i] - mean) * std_inv
            let scaled = normalized * self.gamma.data[i] + self.beta.data[i]
            result.push(scaled)
        }

        return Tensor::vector(result)
    }

    --- 矩阵前向传播（按行归一化）
    fn forward_2d(self, x: Tensor) -> Tensor {
        let batch_size = x.shape.dims[0]
        let features = x.shape.dims[1]

        if features != self.normalized_shape {
            io.println("Error: 特征维度不匹配")
            exit(1)
        }

        let mut result = []

        for b in 0..batch_size {
            -- 计算当前行的均值
            let base = b * features
            let mut mean = 0.0
            for f in 0..features {
                mean = mean + x.data[base + f]
            }
            mean = mean / features

            -- 计算方差
            let mut variance = 0.0
            for f in 0..features {
                let diff = x.data[base + f] - mean
                variance = variance + diff * diff
            }
            variance = variance / features

            -- 归一化并应用参数
            let std_inv = 1.0 / math.sqrt(variance + self.eps)

            for f in 0..features {
                let normalized = (x.data[base + f] - mean) * std_inv
                let scaled = normalized * self.gamma.data[f] + self.beta.data[f]
                result.push(scaled)
            }
        }

        return Tensor::matrix(batch_size, features, result)
    }
}

-- |===========================================================================|
-- |                       RMS Normalization                                    |
-- |===========================================================================|

--- RMSNorm 层
---
--- RMSNorm 是 LayerNorm 的简化版本，去除了均值中心化步骤。
---
--- 公式：
---   y = x / RMS(x) * γ
---   RMS(x) = sqrt(mean(x²) + ε)
---
--- 优势：
--- - 计算更快（无需计算均值）
--- - 效果与 LayerNorm 相当（论文验证）
--- - LLaMA, Mistral, Qwen2 等现代模型使用
type RMSNorm {
    normalized_shape: i64  -- 归一化的维度大小
    eps: f64              -- 数值稳定性常数（默认 1e-6）
    weight: Tensor        -- 缩放参数（仅 γ，无 β）
}

impl RMSNorm {
    --- 创建 RMSNorm 层
    pub fn new(normalized_shape: i64, eps: f64 = 1e-6) -> RMSNorm {
        let shape = Shape { dims: [normalized_shape] }

        return RMSNorm {
            normalized_shape: normalized_shape,
            eps: eps,
            weight: Tensor::ones(shape)  -- 初始化为 1
        }
    }

    --- 前向传播
    pub fn forward(self, x: Tensor) -> Tensor {
        if x.is_vector() {
            return self.forward_1d(x)
        }
        if x.is_matrix() {
            return self.forward_2d(x)
        }

        io.println("Error: RMSNorm 支持 1D 或 2D 张量")
        exit(1)
    }

    --- 向量前向传播
    fn forward_1d(self, x: Tensor) -> Tensor {
        if x.size() != self.normalized_shape {
            io.println("Error: 输入维度与 normalized_shape 不匹配")
            exit(1)
        }

        -- 计算 RMS（均方根）
        let mut sum_sq = 0.0
        for i in 0..self.normalized_shape {
            sum_sq = sum_sq + x.data[i] * x.data[i]
        }
        let rms = math.sqrt(sum_sq / self.normalized_shape + self.eps)

        -- 归一化并应用权重
        let rms_inv = 1.0 / rms
        let mut result = []
        for i in 0..self.normalized_shape {
            result.push(x.data[i] * rms_inv * self.weight.data[i])
        }

        return Tensor::vector(result)
    }

    --- 矩阵前向传播（按行归一化）
    fn forward_2d(self, x: Tensor) -> Tensor {
        let batch_size = x.shape.dims[0]
        let features = x.shape.dims[1]

        if features != self.normalized_shape {
            io.println("Error: 特征维度不匹配")
            exit(1)
        }

        let mut result = []

        for b in 0..batch_size {
            let base = b * features

            -- 计算 RMS
            let mut sum_sq = 0.0
            for f in 0..features {
                sum_sq = sum_sq + x.data[base + f] * x.data[base + f]
            }
            let rms = math.sqrt(sum_sq / features + self.eps)
            let rms_inv = 1.0 / rms

            -- 归一化
            for f in 0..features {
                result.push(x.data[base + f] * rms_inv * self.weight.data[f])
            }
        }

        return Tensor::matrix(batch_size, features, result)
    }
}

-- |===========================================================================|
-- |                      其他归一化方法                                        |
-- |===========================================================================|

--- Batch Normalization（简化版，用于 CNN）
---
--- 注意：BatchNorm 在 NLP 任务中较少使用，
--- 主要用于计算机视觉。这里提供基础实现供参考。
---
--- 公式：
---   y = γ * (x - μ_batch) / √(σ²_batch + ε) + β
type BatchNorm {
    num_features: i64
    eps: f64
    momentum: f64       -- 用于计算运行时统计量
    running_mean: Tensor
    running_var: Tensor
    gamma: Tensor
    beta: Tensor
}

impl BatchNum {
    --- 创建 BatchNorm 层
    pub fn new(num_features: i64, eps: f64 = 1e-5, momentum: f64 = 0.1) -> BatchNorm {
        let shape = Shape { dims: [num_features] }

        return BatchNorm {
            num_features: num_features,
            eps: eps,
            momentum: momentum,
            running_mean: Tensor::zeros(shape),
            running_var: Tensor::ones(shape),
            gamma: Tensor::ones(shape),
            beta: Tensor::zeros(shape)
        }
    }

    --- 训练模式前向传播
    pub fn forward_train(self, x: Tensor) -> Tensor {
        -- x: [N, C, ...] 或 [N, C]
        -- 此处简化为 [N, C] 的 2D 情况

        if not x.is_matrix() {
            io.println("Error: BatchNorm 需要 2D 输入 [N, C]")
            exit(1)
        }

        let n = x.shape.dims[0]     -- batch size
        let c = x.shape.dims[1]     -- channels/features

        if c != self.num_features {
            io.println("Error: 特征数不匹配")
            exit(1)
        }

        -- 计算当前 batch 的均值（沿 batch 维度）
        let mut batch_mean = []
        for ch in 0..c {
            let mut sum = 0.0
            for i in 0..n {
                sum = sum + x.data[i * c + ch]
            }
            batch_mean.push(sum / n)
        }

        -- 计算方差
        let mut batch_var = []
        for ch in 0..c {
            let mut var = 0.0
            for i in 0..n {
                let diff = x.data[i * c + ch] - batch_mean[ch]
                var = var + diff * diff
            }
            batch_var.push(var / n)
        }

        -- 更新运行时统计量
        for ch in 0..c {
            self.running_mean.data[ch] =
                (1.0 - self.momentum) * self.running_mean.data[ch] +
                self.momentum * batch_mean[ch]
            self.running_var.data[ch] =
                (1.0 - self.momentum) * self.running_var.data[ch] +
                self.momentum * batch_var[ch]
        }

        -- 归一化
        let mut result = []
        for i in 0..n {
            for ch in 0..c {
                let normalized = (x.data[i * c + ch] - batch_mean[ch]) /
                                math.sqrt(batch_var[ch] + self.eps)
                let scaled = normalized * self.gamma.data[ch] + self.beta.data[ch]
                result.push(scaled)
            }
        }

        return Tensor::matrix(n, c, result)
    }

    --- 推理模式（使用运行时统计量）
    pub fn forward_eval(self, x: Tensor) -> Tensor {
        if not x.is_matrix() {
            io.println("Error: BatchNorm 需要 2D 输入")
            exit(1)
        }

        let n = x.shape.dims[0]
        let c = x.shape.dims[1]

        let mut result = []
        for i in 0..n {
            for ch in 0..c {
                let normalized = (x.data[i * c + ch] - self.running_mean.data[ch]) /
                                math.sqrt(self.running_var.data[ch] + self.eps)
                let scaled = normalized * self.gamma.data[ch] + self.beta.data[ch]
                result.push(scaled)
            }
        }

        return Tensor::matrix(n, c, result)
    }
}

--- Group Normalization
---
--- 将通道分组后归一化，不受 batch size 影响。
--- 适用于小 batch 场景（如目标检测、分割任务）。
pub fn group_norm(
    x: Tensor,
    num_groups: i64,
    gamma: Tensor,
    beta: Tensor,
    eps: f64 = 1e-5
) -> Tensor {
    if not x.is_matrix() {
        io.Println("Error: group_norm 需要 2D 输入")
        exit(1)
    }

    let n = x.shape.dims[0]
    let c = x.shape.dims[1]

    if c % num_groups != 0 {
        io.println("Error: 通道数必须能被组数整除")
        exit(1)
    }

    let channels_per_group = c / num_groups
    let mut result = []

    for i in 0..n {
        for g in 0..num_groups {
            -- 计算组的均值和方差
            let start_ch = g * channels_per_group
            let mut mean = 0.0
            let mut var = 0.0

            for ch in start_ch..(start_ch + channels_per_group) {
                let val = x.data[i * c + ch]
                mean = mean + val
            }
            mean = mean / channels_per_group

            for ch in start_ch..(start_ch + channels_per_group) {
                let diff = x.data[i * c + ch] - mean
                var = var + diff * diff
            }
            var = var / channels_per_group

            -- 归一化
            let std_inv = 1.0 / math.sqrt(var + eps)

            for ch in start_ch..(start_ch + channels_per_group) {
                let idx = i * c + ch
                let normalized = (x.data[idx] - mean) * std_inv
                result.push(normalized * gamma.data[ch] + beta.data[ch])
            }
        }
    }

    return Tensor::matrix(n, c, result)
}

-- |===========================================================================|
-- |                     实用归一化函数                                         |
-- |===========================================================================|

--- 快速 LayerNorm 函数（无参数版本）
---
--- 当不需要可学习参数时的便捷接口
pub fn layer_norm_quick(x: Tensor, eps: f64 = 1e-5) -> Tensor {
    let norm = LayerNorm::new(x.shape.dims[x.shape.rank() - 1], eps)
    return norm.forward(x)
}

--- 快速 RMSNorm 函数（无参数版本）
pub fn rms_norm_quick(x: Tensor, eps: f64 = 1e-6) -> Tensor {
    let norm = RMSNorm::new(x.shape.dims[x.shape.rank() - 1], eps)
    return norm.forward(x)
}
